sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:_b1 a ns1:ContextAlias;
    ns2:alternateName "pda";
    ns2:identifier "short_name";
    ns1:hasContext <https://ror.org/04gq0w522> .
  
  <https://w3id.org/peh/biochementities/RAvqsJtFWlEoW7y1raGxlv3cz9TYTLv9gbjKIQtWKmc0w>
    a owl:Class;
    dcterms:isPartOf <https://w3id.org/spaces/biochementity/r/vocabulary>;
    ns2:alternateName "PDA";
    ns2:comment """comments: * The CAS number here is associated with the compound in PUBCHEM: https://pubchem.ncbi.nlm.nih.gov/compound/2_4-Diaminotoluene -->  Depositor-Supplied Synonyms here the name in this list appears, but to be double checked. And if the same, I would add 2,4-Diaminotoluene as name and 4-Methyl-m-phenylenediamine as aliases.
* In the CHEBI Database, this CHEBI is associated with: https://www.ebi.ac.uk/chebi/CHEBI:34237 (In this website, the CAS nr does match)""";
    rdfs:label "4-Methyl-m-fenyleendiamine"@nl-be, "4-Methyl-m-phenylenediamine";
    rdfs:subClassOf <https://w3id.org/peh/biochementities/RAjyYX_HMl9eHRIhMuklKHnTl2bCyGU9MDA0LGP776ZxI>,
      ns1:BioChemEntity;
    skos:exactMatch <https://identifiers.org/CHEBI:34237>, <https://identifiers.org/cas:95-80-7>;
    ns1:hasContextAlias sub:_b1;
    ns1:hasGroupLabel "anilines and MOCA" .
}

sub:provenance {
  sub:assertion prov:generatedAtTime "2026-06-30T21:05:39.650204+02:00"^^xsd:dateTime;
    prov:wasAttributedTo orcid:0000-0001-8327-0142 .
}

sub:pubinfo {
  this: dcterms:license <https://creativecommons.org/licenses/by/4.0/>;
    npx:hasNanopubType ns1:BioChemEntity;
    npx:introduces <https://w3id.org/peh/biochementities/RAvqsJtFWlEoW7y1raGxlv3cz9TYTLv9gbjKIQtWKmc0w>;
    rdfs:label "4-Methyl-m-phenylenediamine";
