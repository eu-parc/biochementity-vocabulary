sub:Head {
    this: a np:Nanopublication ;
        np:hasAssertion sub:assertion ;
        np:hasProvenance sub:provenance ;
        np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
    biochementity:RAOiQ4JezoF35ucV3duBWsZg8tVTnuR0tgHH_6tMfW_48 a owl:Class ;
        rdfs:label "Fenvalerate",
            "Fenvaleraat"@nl-be ;
        schema:alternateName "Fenvalerate" ;
        rdfs:subClassOf pehterms:BioChemEntity ;
        skos:exactMatch <https://identifiers.org/CHEBI:5014>,
            <https://identifiers.org/cas:51630-58-1> ;
        pehterms:hasGroupLabel "pesticides",
            "pyrethroid pesticides" .
}

sub:provenance {
    sub:assertion prov:generatedAtTime "2026-06-24T10:39:03.188149+02:00"^^xsd:dateTime .
}

sub:pubinfo {
    sub:sig npx:hasAlgorithm "RSA" ;
        npx:hasPublicKey "" ;
        npx:hasSignature "" ;
        npx:hasSignatureTarget this: ;
        npx:signedBy orcid:0000-0000-0000-0000 .
    this: rdfs:label "Fenvalerate" ;
