sub:Head {
    this: a np:Nanopublication ;
        np:hasAssertion sub:assertion ;
        np:hasProvenance sub:provenance ;
        np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
    biochementity:RAt1xPMfsqRaa6PImSeyCpijnoP23IxLBldOLmV0KGdBc a owl:Class ;
        rdfs:label "Vitamin A",
            "Vitamine A"@nl-be ;
        schema:alternateName "VitA" ;
        rdfs:subClassOf pehterms:BioChemEntity ;
        skos:exactMatch <https://identifiers.org/CHEBI:12777> .
}

sub:provenance {
    sub:assertion prov:generatedAtTime "2026-06-24T10:47:59.034625+02:00"^^xsd:dateTime .
}

sub:pubinfo {
    sub:sig npx:hasAlgorithm "RSA" ;
        npx:hasPublicKey "" ;
        npx:hasSignature "" ;
        npx:hasSignatureTarget this: ;
        npx:signedBy orcid:0000-0000-0000-0000 .
    this: rdfs:label "Vitamin A" ;
        dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
        npx:introduces biochementity:RAt1xPMfsqRaa6PImSeyCpijnoP23IxLBldOLmV0KGdBc ;
