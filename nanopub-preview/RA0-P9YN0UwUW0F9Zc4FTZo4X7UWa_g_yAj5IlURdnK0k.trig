sub:Head {
    this: a np:Nanopublication ;
        np:hasAssertion sub:assertion ;
        np:hasProvenance sub:provenance ;
        np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
    biochementity:RA0-P9YN0UwUW0F9Zc4FTZo4X7UWa_g_yAj5IlURdnK0k a owl:Class ;
        rdfs:label "Dioxin-like PCBs",
            "Dioxine-achtige PCBs (dl-PCBs) (CALUX)"@nl-be ;
        schema:alternateName "Dioxin-like PCBs" ;
        schema:comment "comments: I'm not sure if this can be linked to any key…" ;
        rdfs:subClassOf pehterms:BioChemEntity ;
        pehterms:hasContextAlias sub:_b1 .
    sub:_b1 a pehterms:ContextAlias ;
        schema:alternateName "dlpcb" ;
        schema:identifier "short_name" ;
        pehterms:hasContext <https://ror.org/04gq0w522> .
}

sub:provenance {
    sub:assertion prov:generatedAtTime "2026-06-24T11:20:03.897903+02:00"^^xsd:dateTime ;
        prov:wasAttributedTo orcid:0000-0001-8327-0142 .
}

sub:pubinfo {
    sub:sig npx:hasAlgorithm "RSA" ;
        npx:hasPublicKey "" ;
        npx:hasSignature "" ;
        npx:hasSignatureTarget this: ;
        npx:signedBy orcid:0000-0000-0000-0000 .
    this: rdfs:label "Dioxin-like PCBs" ;
        dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
        npx:introduces biochementity:RA0-P9YN0UwUW0F9Zc4FTZo4X7UWa_g_yAj5IlURdnK0k ;
