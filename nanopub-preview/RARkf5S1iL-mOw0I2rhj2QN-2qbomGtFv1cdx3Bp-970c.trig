        rdfs:subClassOf pehterms:BioChemEntity ;
        skos:exactMatch <https://identifiers.org/inchikey:AYOHIQLKSOJJQH-UHFFFAOYSA-N> ;
        pehterms:hasContextAlias sub:_n466d53bf2afa40cdbff19bd1e3ebad0fb1 ;
