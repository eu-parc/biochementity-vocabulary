sub:Head {
    this: a np:Nanopublication ;
        np:hasAssertion sub:assertion ;
        np:hasProvenance sub:provenance ;
        np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
    biochementity:RAr6rnZ8ObASrm194QibIF_Osr9sqZlu-D72-d0G6a88U a owl:Class ;
        rdfs:label "Zearalenone",
            "Zearalenon"@nl-be ;
