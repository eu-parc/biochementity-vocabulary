@prefix this: <https://w3id.org/np/RAX3jwG4mFwVM8OrYNTPp8Kzx9uTjo-5wagsELzbewft0> .
@prefix sub: <https://w3id.org/np/RAX3jwG4mFwVM8OrYNTPp8Kzx9uTjo-5wagsELzbewft0/> .
@prefix biochementity: <https://w3id.org/peh/biochementities/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix np: <http://www.nanopub.org/nschema#> .
@prefix npx: <http://purl.org/nanopub/x/> .
@prefix orcid: <https://orcid.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sub:Head {
    this: a np:Nanopublication ;
        np:hasAssertion sub:assertion ;
        np:hasProvenance sub:provenance ;
        np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
    biochementity:RAX3jwG4mFwVM8OrYNTPp8Kzx9uTjo-5wagsELzbewft0 a owl:Class ;
        rdfs:label "Mercapturic acid",
            "Mercaptuurzuur"@nl-be ;
        schema:alternateName "Mercapturic acid" ;
        schema:comment """comments: CHEBI keys in our DB refer to N-acetyl-L-cysteine https://www.ebi.ac.uk/chebi/CHEBI:28939. I think it's not 100% correct?
    According to this article https://pubmed.ncbi.nlm.nih.gov/31944156/#:~:text=Mercapturic%20acids%20(N%2Dacetyl%2D,%2Dconjugates%2C%20and%20mercapturic%20acids; --> there is not a single  Mercapturic acid so I don't think we can link this to a key? Is this a sum parameter?""" ;
        rdfs:subClassOf pehterms:BioChemEntity ;
        skos:exactMatch <https://identifiers.org/CHEBI:22198>,
            <https://identifiers.org/CHEBI:28939> ;
        pehterms:hasContextAlias sub:_n4604edf2c5ea48d5b27cd682205b5ab6b1 ;
        pehterms:hasGroupLabel "volatile organic compounds" .
    sub:_n4604edf2c5ea48d5b27cd682205b5ab6b1 a pehterms:ContextAlias ;
        schema:alternateName "ma" ;
        schema:identifier "short_name" ;
        pehterms:hasContext <https://ror.org/04gq0w522> .
}

sub:provenance {
    sub:assertion prov:generatedAtTime "2026-06-24T10:39:10.885814+02:00"^^xsd:dateTime .
}

sub:pubinfo {
    sub:sig npx:hasAlgorithm "RSA" ;
        npx:hasPublicKey "" ;
        npx:hasSignature "" ;
        npx:hasSignatureTarget this: ;
        npx:signedBy orcid:0000-0000-0000-0000 .
    this: rdfs:label "Mercaptuurzuur" ;
        dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
        npx:introduces biochementity:RAX3jwG4mFwVM8OrYNTPp8Kzx9uTjo-5wagsELzbewft0 ;
        prov:generatedAtTime "2026-06-24T10:39:10.885814+02:00"^^xsd:dateTime .
}
