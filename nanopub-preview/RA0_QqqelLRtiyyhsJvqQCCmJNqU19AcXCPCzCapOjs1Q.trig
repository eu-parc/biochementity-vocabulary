sub:Head {
    this: a np:Nanopublication ;
        np:hasAssertion sub:assertion ;
        np:hasProvenance sub:provenance ;
        np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
    biochementity:RA0_QqqelLRtiyyhsJvqQCCmJNqU19AcXCPCzCapOjs1Q a owl:Class ;
        rdfs:label "Arsenic(III) acid",
            "Arseen(III)zuur"@nl-be ;
        schema:alternateName "As(III)",
            "As(III)"@nl-be ;
        schema:comment """comments: * I don't think the CAS nr in our DB is correct
    * For the CHEBI key --> this is the link: https://www.ebi.ac.uk/chebi/CHEBI:35828
    * I did not find anything in PUBCHEM?""" ;
        rdfs:subClassOf pehterms:BioChemEntity ;
        skos:exactMatch <https://identifiers.org/CHEBI:35828> ;
        pehterms:hasContextAlias sub:_n219f9d12a8214acba5dd4640b43b1660b1 ;
        pehterms:hasGroupLabel "metals" ;
        pehterms:isMetaboliteOf biochementity:RAVfL1GWGrwt1BXSFBJ1ukAjCXXWqDlv7A8MbuLytxfDc .
    sub:_n219f9d12a8214acba5dd4640b43b1660b1 a pehterms:ContextAlias ;
        schema:alternateName "asthree" ;
        schema:identifier "short_name" ;
        pehterms:hasContext <https://ror.org/04gq0w522> .
}

sub:provenance {
