sub:Head {
    this: a np:Nanopublication ;
        np:hasAssertion sub:assertion ;
        np:hasProvenance sub:provenance ;
        np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
    biochementity:RAlvXNN6xODZM0_UWo6WKk-Y6LK63di60I8JoOIN4J1_c a owl:Class ;
        rdfs:label "Deoxynivalenol" ;
        schema:alternateName "DON" ;
        rdfs:subClassOf pehterms:BioChemEntity ;
        skos:exactMatch <https://identifiers.org/CHEBI:10022>,
            <https://identifiers.org/cas:51481-10-8> ;
        pehterms:hasGroupLabel "mycotoxins" .
}

sub:provenance {
