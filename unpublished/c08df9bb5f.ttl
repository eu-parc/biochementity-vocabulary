@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/c08df9bb5f> a owl:Class ;
    rdfs:label "Molybdenum",
        "Molybdeen"@nl-be ;
    schema1:alternateName "Mo",
        "Mo"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND4E5V1PY6CGZC1PB9>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:28685>,
        <https://identifiers.org/cas:16065-87-5>,
        <https://identifiers.org/cas:7439-98-7>,
        <https://identifiers.org/inchikey:ZOKXTWBITQBERF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:23932> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mo" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "metals" .

