@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/ffd07c9c23> a owl:Class ;
    rdfs:label "N-ethyl-perfluorooctane sulfonamidoacetate",
        "Lineair + vertakt 2-(n-ethylperfluorooctaansulfonamido) azijnzuur"@nl-be ;
    schema1:alternateName "EtPFOSAA",
        "L+B EtPFOSAA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "lbetpfosaa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

