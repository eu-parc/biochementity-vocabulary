@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/20abdc4aa8> a owl:Class ;
    rdfs:label "(3,4-dichlorophenyl)urea",
        "3,4-dichlorophenylurea fungiciden"@nl-be ;
    schema1:alternateName "(3,4-dichlorophenyl)urea",
        "DCPU"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:83464>,
        <https://identifiers.org/cas:2327-02-8>,
        <https://identifiers.org/inchikey:CYESCLHCWJKRKM-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:16854> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dcpu" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/2a8b755edb> .

