@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/b3a6b0c457> a owl:Class ;
    rdfs:label "Linear 8:2 polyfluoroalkyl phosphoric acid diesters",
        "Lineair 8:2 fluortelomeerfosfaat diester"@nl-be ;
    schema1:alternateName "8:2 Fluorotelomer phosphate diester",
        "8:2 diPAP",
        "8:2 diPAP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:83540>,
        <https://identifiers.org/cas:678-41-1>,
        <https://identifiers.org/inchikey:AFWOYEYXUDHGHF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:3022253> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "eightdipap" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

