        <https://identifiers.org/cas:13864-02-3>,
        <https://identifiers.org/cas:7440-45-1>,
        <https://identifiers.org/inchikey:GWXLDORMOJMVQZ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:23974> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ce" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "metals" .

