<https://w3id.org/peh/biochementities/3cc3b8d3e6> a owl:Class ;
    rdfs:label "Cerium",
        "Cerium"@nl-be ;
    schema1:alternateName "Ce",
        "Ce"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND4E5V1PY6CGZC1PB9>,
