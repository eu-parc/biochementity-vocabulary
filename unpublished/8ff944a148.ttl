@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8ff944a148> a owl:Class ;
    rdfs:label "2-propoxyacetic acid",
        "2-propoxyazijnzuur"@nl-be ;
    schema1:alternateName "PAA" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:54497-00-6>,
        <https://identifiers.org/inchikey:SGUYGLMQEOSQTH-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:100383> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "paa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "glycol ethers" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/cae62f7bd4> .

