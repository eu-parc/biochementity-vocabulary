@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/c8326b55bf> a owl:Class ;
    rdfs:label "7-OH-(Mono-methyl-octyl) phthalate",
        "Mono(7-hydroxy-isononyl) phthalate"@nl-be ;
    schema1:alternateName "OH-MiNP",
        "OH-MiNP"@nl-be ;
    schema1:comment "source: http://exposome-explorer.iarc.fr/compounds/1451" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:RWCHSWLUPRJYEX-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mhnp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/015aee8b1a> .

