@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/d98a08d508> a owl:Class ;
    rdfs:label "Linear Perfluoro-4-ethylcyclohexane sulfonic acid",
        "Lineair Perfluor-4-ethylcyclohexaansulfonzuur"@nl-be ;
    schema1:alternateName "PFECHS",
        "Perfluoro-4-ethylcyclohexane",
        "PFECHS"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:646-83-3>,
        <https://identifiers.org/inchikey:ICKAEAFPESRWOT-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:101650> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfechs" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

