@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8a785d544e> a owl:Class ;
    rdfs:label "Cis-nonachlor",
        "Cis-nonachloor"@nl-be ;
    schema1:alternateName "Cis-nonachlor" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:5103-73-1>,
        <https://identifiers.org/inchikey:OCHOKXCPKDPNQU-MSFPVELZSA-N>,
        <https://identifiers.org/pubchem.compound:12313426> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "cisnonac" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds",
        "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/d17f057449> .

