@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/c620896c8d> a owl:Class ;
    rdfs:label "5-hydroxy-N-ethyl-2-pyrrolidone",
        "5-hydroxy-N-ethyl-2-pyrrolidon"@nl-be ;
    schema1:alternateName "5-HNEP" ;
    schema1:comment "comments: * The INCHIKEY takes me to this pubchem link:https://pubchem.ncbi.nlm.nih.gov/compound/1-Ethyl-5-hydroxy-2-pyrrolidinone, but I'm not sure it is the same compound?" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:RIOOHZIYIQTLNP-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "hnep" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "aprotic solvents" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/1037dff372> .

