@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/2825b69076> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 81",
        "Polychloorbifenyl 81"@nl-be ;
    schema1:alternateName "3,4,4',5-Tetrachlorobiphenyl",
        "PCB 81",
        "PCB 81"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81516>,
        <https://identifiers.org/cas:70362-50-4>,
        <https://identifiers.org/inchikey:BHWVLZJTVIYLIV-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:51043> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb81" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

