@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/999edda143> a owl:Class ;
    rdfs:label "Platinum",
        "Platina"@nl-be ;
    schema1:alternateName "Pt",
        "Pt"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND4E5V1PY6CGZC1PB9>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:33364>,
        <https://identifiers.org/cas:7440-06-4>,
        <https://identifiers.org/inchikey:BASFCYQUMIYNBI-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:23939> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pt" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "metals" .

