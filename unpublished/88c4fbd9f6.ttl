@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/88c4fbd9f6> a owl:Class ;
    rdfs:label "4-chloro-alpha-isopropyl benzene acetic acid",
        "4-chloor-alfa-isopropylbenzeenazijnzuur"@nl-be ;
    schema1:alternateName "CPBA" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "cpba" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides",
        "pyrethroid pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/6c4eee9eae>,
        <https://w3id.org/peh/biochementities/db8a787bd3> .

