    schema1:alternateName "BDE-33",
        "bde 33",
        "bde-33",
        "bde33" ;
    schema1:comment "comments: * Since there are no identifiers in our db, is it this compound? https://pubchem.ncbi.nlm.nih.gov/compound/tribromodiphenyl%20ether" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "bde33" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" .

