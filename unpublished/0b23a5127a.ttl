@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/0b23a5127a> a owl:Class ;
    rdfs:label "Linear Perfluorododecane sulfonic acid",
        "Lineair Perfluoro-n-dodecaansulfonzuur"@nl-be ;
    schema1:alternateName "PFDoDS",
        "PFDoDS"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:79780-39-5>,
        <https://identifiers.org/inchikey:CFCRODHVHXGTPC-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:3018866> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfdods" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

