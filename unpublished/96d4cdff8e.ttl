@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/96d4cdff8e> a owl:Class ;
    rdfs:label "Benzophenone",
        "Benzofenon"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_73335> ;
    schema1:alternateName "BP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:41308>,
        <https://identifiers.org/cas:119-61-9>,
        <https://identifiers.org/inchikey:RWCCWEUUXYIKHB-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:3102> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "bp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "benzophenones",
        "uv filters" .

