@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/f316a3faff> a owl:Class ;
    rdfs:label "Pentylparaben",
        "PentylP (pentylparabeen)"@nl-be ;
    schema1:alternateName "Pentyl 4-hydroxybenzoate",
        "pentylP" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND6Q9907FMD4GPNFWX>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:6521-29-5>,
        <https://identifiers.org/inchikey:ZNSSPLQZSUWFJT-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:23019> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pentip" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "parabens" .

