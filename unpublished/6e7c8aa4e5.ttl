@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/6e7c8aa4e5> a owl:Class ;
    rdfs:label "Mono(2-ethyl-5-hydroxy-hexyl) phthalate",
        "Mono-(2-ethyl-5-hydroxyhexyl)ftalaat"@nl-be ;
    schema1:alternateName "5OH-MEHP",
        "5OH-MEHP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:132607>,
        <https://identifiers.org/cas:40321-99-1>,
        <https://identifiers.org/inchikey:RYPQSGURZSTFSX-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:170295> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ohmehp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/95e3fd49d0> .

