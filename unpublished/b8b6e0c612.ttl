@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/b8b6e0c612> a owl:Class ;
    rdfs:label "Chlorpyrifos-methyl",
        "Chloorpyrifos-methyl"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "chlorpyrifos-methyl" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34632>,
        <https://identifiers.org/cas:5598-13-0>,
        <https://identifiers.org/inchikey:HRBKVYFZANMGRE-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:21803> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "chlormet" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

