@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/d9cfaccbb4> a owl:Class ;
    rdfs:label "Neosolaniol",
        "Neosolaniol"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25442> ;
    schema1:alternateName "NEO" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:36519-25-2>,
        <https://identifiers.org/inchikey:TVZHDVCTOCZDNE-WVJYZQHISA-N>,
        <https://identifiers.org/pubchem.compound:13818797> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "neo" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" .

