@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/1145018bfb> a owl:Class ;
    rdfs:label "Total Hexabromocyclododecane",
        "Hexabromocyclododecaan"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_79314> ;
    schema1:alternateName "total HBCD",
        "total HBCD"@nl-be ;
    schema1:comment "comments: *For the CHEBI Key in our DB, I get the link to this compound, but I'm not sure it is the same? https://www.ebi.ac.uk/chebi/CHEBI:134063" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:134063>,
        <https://identifiers.org/cas:3194-55-6>,
        <https://identifiers.org/inchikey:LEOCKULGXOQRTQ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:https://pubchem.ncbi.nlm.nih.gov/compound/Hexabromocyclododecane> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "hbcd" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" .

