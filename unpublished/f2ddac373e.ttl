@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/f2ddac373e> a owl:Class ;
    rdfs:label "Endrin",
        "Endrin"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "endrin" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81526>,
        <https://identifiers.org/cas:72-20-8>,
        <https://identifiers.org/inchikey::DFBKLUNHFCTMDC-GKRDHZSOSA-N>,
        <https://identifiers.org/pubchem.compound:12358480> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "endrin" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

