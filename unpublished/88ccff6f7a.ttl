<https://w3id.org/peh/biochementities/88ccff6f7a> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 206",
        "Polychloorbifenyl 206"@nl-be ;
    schema1:alternateName "2,2',3,3',4,4',5,5',6-Nonachlorobiphenyl",
        "PCB 206",
        "PCB 206"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:40186-72-9>,
        <https://identifiers.org/cas:53742-07-7>,
        <https://identifiers.org/inchikey:JFIMDKGRGPNPRQ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:38411> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb206" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

