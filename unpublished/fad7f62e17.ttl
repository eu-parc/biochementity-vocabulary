@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/fad7f62e17> a owl:Class ;
    rdfs:label "Carbofuran-phenol",
        "Carbofuran-fenol"@nl-be ;
    schema1:alternateName "carbofuran-phenol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:38474>,
        <https://identifiers.org/cas:1563-38-8>,
        <https://identifiers.org/inchikey:WJGPNUBJBMCRQH-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:15278> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "carphe" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "carbamate pesticides",
        "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/577cbf15f3> .

