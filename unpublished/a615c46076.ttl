        <https://identifiers.org/inchikey:RMPWIIKNWPVWNG-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:37037> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
