@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/peh/biochementities/00bd658f08> a owl:Class ;
    rdfs:label "4-Methyl-m-phenylenediamine",
        "4-Methyl-m-fenyleendiamine"@nl-be ;
    schema1:alternateName "PDA" ;
    schema1:comment """comments: * The CAS number here is associated with the compound in PUBCHEM: https://pubchem.ncbi.nlm.nih.gov/compound/2_4-Diaminotoluene -->  Depositor-Supplied Synonyms here the name in this list appears, but to be double checked. And if the same, I would add 2,4-Diaminotoluene as name and 4-Methyl-m-phenylenediamine as aliases.
* In the CHEBI Database, this CHEBI is associated with: https://www.ebi.ac.uk/chebi/CHEBI:34237 (In this website, the CAS nr does match)""" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND3BTCXN6EEBJ8TRXB>,
        pehterms:BioChemEntity ;
    skos:exactMatch "https://identifiers.org/CHEBI:34237"^^xsd:anyURI,
        "https://identifiers.org/cas:95-80-7"^^xsd:anyURI ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pda" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] .

