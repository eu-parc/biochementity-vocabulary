@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/796cb71129> a owl:Class ;
    rdfs:label "Linear Perfluorobutylsulphonamide",
        "Lineair Perfluoro-n-butaansulfonamide"@nl-be ;
    schema1:alternateName "PFBSA",
        "Perfluorobutane",
        "sulfonamide",
        "PFBSA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:30334-69-1>,
        <https://identifiers.org/inchikey:FUVKFLJWBHVMHX-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:10958205> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfbsa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

