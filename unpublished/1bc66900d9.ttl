<https://w3id.org/peh/biochementities/1bc66900d9> a owl:Class ;
    rdfs:label "3-phenoxybenzoic acid",
        "Fenoxybenzoëzuur"@nl-be ;
    schema1:alternateName "3PBA",
        "3PBA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:72631>,
        <https://identifiers.org/cas:3739-38-6>,
        <https://identifiers.org/inchikey:NXTDJHZGHOFSQG-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:19539> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "threepba" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides",
        "pyrethroid pesticides" ;
