@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/561eee706e> a owl:Class ;
    rdfs:label "Linear Perfluorotridecanoic acid",
        "Lineair Perfluoro-n-tridecaanzuur"@nl-be ;
    schema1:alternateName "lpftrda",
        "PFTrDA"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/df361a1fa4>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:72629-94-8>,
        <https://identifiers.org/inchikey:LVDGGZAZAYHXEY-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:3018355> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pftrda" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" ;
    pehterms:isIsomerOf <https://w3id.org/peh/biochementities/01KT6EDSFQGNCA3YZCECPAP8ZC> .

