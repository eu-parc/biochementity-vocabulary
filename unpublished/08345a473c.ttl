@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/08345a473c> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 77",
        "Polychloorbifenyl 77"@nl-be ;
    schema1:alternateName "PCB 77",
        "PCB 77"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:1367>,
        <https://identifiers.org/cas:32598-13-3>,
        <https://identifiers.org/cas:80333-65-9>,
        <https://identifiers.org/inchikey:UQMGJOKDKOLIDP-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:36187> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb77" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

