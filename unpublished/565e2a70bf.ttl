    rdfs:label "Linear N-Ethyl-perfluorooctane sulphonamidoethanol",
        "Lineair N-ethylperfluorooctaansulfonamido-ethanol"@nl-be ;
    schema1:alternateName "2-(N-ethylperfluorooctanesulfonamido)ethyl alcohol",
        "EtPFOSE",
        "EtPFOSE"@nl-be ;
