@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/765b0a8585> a owl:Class ;
    rdfs:label "Deoxynivalenol-15-acetate",
        "Deoxynivalenol-15-acetaat"@nl-be ;
    schema1:alternateName "15-acetyl-DON" ;
    schema1:comment "comments: Is this compound the same? https://pubchem.ncbi.nlm.nih.gov/compound/15-Acetyldeoxynivalenol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "facetyldon" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/56872ff940> .

