@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/e6c38d8e40> a owl:Class ;
    rdfs:label "Ochratoxin-alpha",
        "Ochratoxine-alfa"@nl-be ;
    schema1:alternateName "OTα" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:133917>,
        <https://identifiers.org/cas:19165-63-0>,
        <https://identifiers.org/inchikey:OSFWJKYWJMZKSM-SCSAIBSYSA-N>,
        <https://identifiers.org/pubchem.compound:107911> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "otalpha" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/1087bec7ef> .

