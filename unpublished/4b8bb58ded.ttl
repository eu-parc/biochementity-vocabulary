@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/4b8bb58ded> a owl:Class ;
    rdfs:label "α-zearalenol-glucuronide",
        "α-zearalenol-glucuronide"@nl-be ;
    schema1:alternateName "α-ZEL-Glc" ;
    schema1:comment "comments: Didn't find this" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "azelglca" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/567b9e5017> .

