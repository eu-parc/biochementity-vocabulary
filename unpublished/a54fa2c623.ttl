@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/a54fa2c623> a owl:Class ;
    rdfs:label "Mono-iso-propyl phthalate",
        "Mono-isopropylftalaat"@nl-be ;
    schema1:alternateName "MiPrP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:132587>,
        <https://identifiers.org/cas:35118-50-4>,
        <https://identifiers.org/inchikey:CXJOEMLCEGZVPL-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:118770> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "miprp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/c7be1cc2b3> .

