@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/668c27e0fe> a owl:Class ;
    rdfs:label "Linear Perfluorohexylphosphonic acid",
        "Lineair perfluorhexylfosfonzuur"@nl-be ;
    schema1:alternateName "PFHxPA",
        "Phosphonic acid perfluoro-C6-12-alkyl derivs.",
        "PFHxPA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:40143-76-8>,
        <https://identifiers.org/cas:68412-68-0>,
        <https://identifiers.org/inchikey:AGCUFKNHQDVTAD-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:15930820> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfhxpa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

