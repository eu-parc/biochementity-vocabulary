<https://w3id.org/peh/biochementities/644aaf16e7> a owl:Class ;
    rdfs:label "Linear 2,2,3-trifluoro-3-[1,1,2,2,3,3-hexafluoro-3-(trifluoromethoxy)propoxy]propanoic acid",
        "Lineair 4,8-dioxa-3H-perfluornonaanzuur"@nl-be ;
    schema1:alternateName "ADONA",
        "adona",
        "ADONA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
