@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/2626a83d05> a owl:Class ;
    rdfs:label "AFB-N7-guanine",
        "AFB-N7-guanine"@nl-be ;
    schema1:alternateName "AFB-N7-guanine" ;
    schema1:comment """comments: The INCHIKEY only refers me here: https://www.medkoo.com/products/20764

CAS nr seems to be 79982-94-8 but not 100% sure - did not find reliable source
source: https://pubmed.ncbi.nlm.nih.gov/16978023/#:~:text=The%20limit%20of%20quantitation%20for,AFB(1)%2Dexposed%20populations.""" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:GXTQFZWLCDHVQV-CKJDJMSUSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "afbgua" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/be3b948805> .

