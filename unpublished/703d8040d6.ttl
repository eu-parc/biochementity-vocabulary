<https://w3id.org/peh/biochementities/703d8040d6> a owl:Class ;
    rdfs:label "2,4,5-trichlorophenol",
        "2,4,5-trichloorfenol"@nl-be ;
    schema1:alternateName "2,4,5-TCP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:28520>,
        <https://identifiers.org/cas:95-95-4>,
        <https://identifiers.org/inchikey:LHJGJYXLEPZJPM-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:7271> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "tcp245" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/3481d765c8>,
        <https://w3id.org/peh/biochementities/cdd86cd306> .

