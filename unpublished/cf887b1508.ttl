@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/cf887b1508> a owl:Class ;
    rdfs:label "Linear Perfluoro-3,6-dioxaheptanoic acid",
        "Lineair Perfluor-3,6-dioxaheptaanzuur"@nl-be ;
    schema1:alternateName "NFDHA",
        "NFDHA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:151772-58-6>,
        <https://identifiers.org/inchikey:PPWRLPJIHGWGFH-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:2782393> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "nfdha" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

