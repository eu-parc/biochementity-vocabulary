@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8d6e1a506f> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 172",
        "Polychloorbifenyl 172"@nl-be ;
    schema1:alternateName "2,2',3,3',4,5,5'-Heptachlorobiphenyl",
        "PCB 172",
        "PCB 172"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:52663-74-8>,
        <https://identifiers.org/inchikey:HOPMUCXYRNOABF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:40481> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb172" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

