@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/9282fd4a19> a owl:Class ;
    rdfs:label "Imidacloprid-5-OH",
        "Imidacloprid-5-OH"@nl-be ;
    schema1:alternateName "5-Hydroxyimidacloprid",
        "Imidacloprid-5-OH",
        "Imidacloprid-5-OH"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:MATMQDMQFSFQHB-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:136241533> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "imidacloprid5oh" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/5a8e126c1b> .

