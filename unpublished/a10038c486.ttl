@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/a10038c486> a owl:Class ;
    rdfs:label "Cortisol",
        "Cortisol"@nl-be ;
    schema1:alternateName "Cortisol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:17650>,
        <https://identifiers.org/pubchem.compound:5754>,
        <https://loinc.org/LP14161-1> .

