@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8bb8e2b93a> a owl:Class ;
    rdfs:label "7-Oxo-(mono-methyl-octyl) phthalate",
        "7-oxo-(mono-methyloctyl)ftalaat"@nl-be ;
    schema1:alternateName "oxo-MiNP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:UFUNVAIKYOYYBB-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "monp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/015aee8b1a> .

