@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/3648eb0ecc> a owl:Class ;
    rdfs:label "2-OH-Mono-iso-butylphthalate",
        "2-OH-mono-isobutylftalaat"@nl-be ;
    schema1:alternateName "OH-MiBP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:64339-39-5>,
        <https://identifiers.org/inchikey:LTLINVWNJJAVGH-UHFFFAOYSA-M>,
        <https://identifiers.org/pubchem.compound:71371900> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ohmibp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/72ef88ed5b> .

