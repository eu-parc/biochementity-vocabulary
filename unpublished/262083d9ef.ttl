@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/262083d9ef> a owl:Class ;
    rdfs:label "Cyhalothrin" ;
    schema1:alternateName "Cyhalothrin" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:4035>,
        <https://identifiers.org/cas:68085-85-8> ;
    pehterms:hasGroupLabel "pesticides",
        "pyrethroid pesticides" .

