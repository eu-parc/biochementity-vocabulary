@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/6fe606670c> a owl:Class ;
    rdfs:label "Mono-methyl phthalate",
        "Mono-methyl ftalaat"@nl-be ;
    schema1:alternateName "MMP",
        "MMP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:89749>,
        <https://identifiers.org/cas:4376-18-5>,
        <https://identifiers.org/inchikey:FNJSWIPFHMKRAT-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:20392> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mmp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/55e4e1b391> .

