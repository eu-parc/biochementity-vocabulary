@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/052ad23257> a owl:Class ;
    rdfs:label "4-hydroxyphenanthrene",
        "4-hydroxyphenanthrene"@nl-be ;
    schema1:alternateName "4-PHEN" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:20469>,
        <https://identifiers.org/cas:7651-86-7>,
        <https://identifiers.org/inchikey:SIMYIUXARJLHEA-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:82105> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "fourhphe" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/4cda9c8c72> .

