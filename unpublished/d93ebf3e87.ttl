@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/d93ebf3e87> a owl:Class ;
    rdfs:label "Linear Perfluoroheptanoic acid",
        "Lineair Perfluoro-n-heptaanzuur"@nl-be ;
    schema1:alternateName "lpfhpa",
        "PFHpA"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/4910c0fa4c>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:35547>,
        <https://identifiers.org/cas:375-85-9>,
        <https://identifiers.org/inchikey:ZWBAMYVPMDSJGQ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:67818> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfhpa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" ;
    pehterms:isIsomerOf <https://w3id.org/peh/biochementities/01KT6EDSFQYE9VRHZQAN5SW39T> .

