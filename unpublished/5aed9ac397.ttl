@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/5aed9ac397> a owl:Class ;
    rdfs:label "Linear Perfluorodecylphosphonic acid",
        "Lineair perfluordecylfosfonzuur"@nl-be ;
    schema1:alternateName "PFDPA",
        "PFDPA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:52299-26-0>,
        <https://identifiers.org/inchikey:CTGNCBOZEMOASL-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:85828788> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfdpa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

