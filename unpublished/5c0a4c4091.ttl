@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/5c0a4c4091> a owl:Class ;
    rdfs:label "Boscalid",
        "Boscalid"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "Boscalid" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81822>,
        <https://identifiers.org/cas:188425-85-6>,
        <https://identifiers.org/inchikey:WYEMLYFITZORAB-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:213013> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "boscalid" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

