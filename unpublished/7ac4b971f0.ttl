@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/7ac4b971f0> a owl:Class ;
    rdfs:label "Oxychlordane",
        "Oxychlordaan"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "OXC",
        "OXC"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81541>,
        <https://identifiers.org/cas:27304-13-8>,
        <https://identifiers.org/inchikey:VWGNQYSIWFHEQU-KGEUUOKHSA-N>,
        <https://identifiers.org/pubchem.compound:13785700> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "oxc" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds",
        "pesticides" .

