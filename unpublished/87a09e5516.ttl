@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/87a09e5516> a owl:Class ;
    rdfs:label "Trioctyltin",
        "Trioctyltin"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "TOT",
        "Tri-N-octyltin",
        "hydride" ;
    schema1:comment "comments: Please confirm that Tri-N-octyltin hydride and TOT are the same" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:869-59-0>,
        <https://identifiers.org/inchikey:XMHKTINRBAKEDS-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:5360423> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "tot" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

