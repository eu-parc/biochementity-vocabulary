@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/75ae56105e> a owl:Class ;
    rdfs:label "Mono(2-ethyl-5-oxohexyl) adipate",
        "Mono(2-ethyl-5-oxohexyl) adipate"@nl-be ;
    schema1:alternateName "oxo-MEHA",
        "oxo-MEHA"@nl-be ;
