@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/e03dfb6241> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 105",
        "Polychloorbifenyl 105"@nl-be ;
    schema1:alternateName "PCB 105",
        "PCB 105"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81518>,
        <https://identifiers.org/cas:32598-14-4>,
        <https://identifiers.org/inchikey:WIDHRBRBACOVOY-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:36188> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb105" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

