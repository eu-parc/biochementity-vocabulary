@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/ff8516cc03> a owl:Class ;
    rdfs:label "Aminomethylyphosphonic acid",
        "Aminomethylfosfoonzuur"@nl-be ;
    schema1:alternateName "AMPA",
        "AMPA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:28812>,
        <https://identifiers.org/cas:1066-51-9>,
        <https://identifiers.org/inchikey:MGRVRXRGTBOSHW-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:14017> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ampa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/f8ecd803f9> .

