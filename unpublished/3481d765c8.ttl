@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/3481d765c8> a owl:Class ;
    rdfs:label "HCH",
        "HCH"@nl-be ;
    schema1:alternateName "HCHbis" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:24536>,
        <https://identifiers.org/cas:608-73-1> ;
    pehterms:hasGroupLabel "pesticides" .

