@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8ce941e0e9> a owl:Class ;
    rdfs:label "Dibutyltin",
        "Dibutyltin"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "DBT" ;
    schema1:comment """comments: This one is a bit weird. The inchikey in our db directs me here: https://pubchem.ncbi.nlm.nih.gov/compound/6484 but if I then search for 	
Dibutyl-stannane then I go to this pubchem reference https://pubchem.ncbi.nlm.nih.gov/compound/Dibutylstannane. So, which one is the correct one?""" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:AYOHIQLKSOJJQH-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dbt" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

