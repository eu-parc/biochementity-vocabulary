@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/4d8f49f24e> a owl:Class ;
    rdfs:label "Permethrin" ;
    schema1:alternateName "Permethrin" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34911>,
        <https://identifiers.org/cas:52645-53-1> ;
    pehterms:hasGroupLabel "pesticides",
        "pyrethroid pesticides" .

