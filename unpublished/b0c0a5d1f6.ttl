@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/b0c0a5d1f6> a owl:Class ;
    rdfs:label "T-2 tetraol toxin",
        "T-2 tetraol-toxine"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25442> ;
    schema1:alternateName "T-2 tetraol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:172528>,
        <https://identifiers.org/cas:34114-99-3>,
        <https://identifiers.org/inchikey:ZAXZBJSXSOISTF-LYFQSNBGSA-N>,
        <https://identifiers.org/pubchem.compound:9904331> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ttetraol" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" .

