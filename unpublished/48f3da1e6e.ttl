@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/48f3da1e6e> a owl:Class ;
    rdfs:label "Perfluorotetradecanoic acid",
        "Lineair + vertakt Perfluoro-n-tetradecaanzuur"@nl-be ;
    schema1:alternateName "PFTeDA",
        "L+B PFTeDA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "lbpfteda" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

