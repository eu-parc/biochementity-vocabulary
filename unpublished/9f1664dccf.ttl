<https://w3id.org/peh/biochementities/9f1664dccf> a owl:Class ;
    rdfs:label "cotinine",
        "cotinine"@nl-be ;
    schema1:alternateName "cotinine",
        "cotinine"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND363JBS1N385ZEE1Z> ;
    skos:exactMatch <https://identifiers.org/CHEBI:68641>,
