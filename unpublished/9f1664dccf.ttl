        <https://identifiers.org/inchikey:UIKROCXWUNQSPJ-VIFPVBQESA-N>,
        <https://identifiers.org/pubchem.compound:854019> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "cot" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "alkaloid" .

