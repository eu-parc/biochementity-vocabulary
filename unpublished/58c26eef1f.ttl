@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/58c26eef1f> a owl:Class ;
    rdfs:label "2-(2-ethoxyethoxy)ethanol",
        "2-(2-ethoxyethoxy)ethanol"@nl-be ;
    schema1:alternateName "DEGEE" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:40572>,
        <https://identifiers.org/cas:111-90-0> ;
    pehterms:hasGroupLabel "glycol ethers" .

