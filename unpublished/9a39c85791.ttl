@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/9a39c85791> a owl:Class ;
    rdfs:label "Desethyl desisopropyl 2-hydroxy atrazine",
        "Desethyl desisopropyl 2-hydroxyatrazine"@nl-be ;
    schema1:alternateName "Desethyl desisopropyl 2-hydroxy atrazine" ;
    schema1:comment "comments: I don't find this compound anywhere butt according to google AI is this compound? https://pubchem.ncbi.nlm.nih.gov/compound/hydroxyatrazine#section=3D-Conformer" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "desdesiso2hyat" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "herbicides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/0df789fdea> .

