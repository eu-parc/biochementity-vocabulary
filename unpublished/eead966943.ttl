@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/eead966943> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 123",
        "Polychloorbifenyl 123"@nl-be ;
    schema1:alternateName "2',3,4,4',5-Pentachlorobiphenyl",
        "PCB 123",
        "PCB 123"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81521>,
        <https://identifiers.org/cas:65510-44-3>,
        <https://identifiers.org/inchikey:YAHNWSSFXMVPOU-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:47650> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb123" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

