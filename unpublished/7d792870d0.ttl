<https://w3id.org/peh/biochementities/7d792870d0> a owl:Class ;
    rdfs:label "Linear Perfluorooctane sulfonic acid",
        "Lineair Perfluoro-n-octaansulfonzuur"@nl-be ;
    schema1:alternateName "lpfos",
        "L-PFOS"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/f263dca71c>,
