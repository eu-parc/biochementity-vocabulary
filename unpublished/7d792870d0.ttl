    skos:exactMatch <https://identifiers.org/CHEBI:39421>,
        <https://identifiers.org/cas:1763-23-1>,
        <https://identifiers.org/cas:2795-39-3>,
        <https://identifiers.org/inchikey:YFSUTJLHUFNCNZ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:74483> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfos" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" ;
    pehterms:isIsomerOf <https://w3id.org/peh/biochementities/01KT6EDSFQGR84WPZDJXJXT546> .

