@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/f4a9ff583d> a owl:Class ;
    rdfs:label "N,N-Dimethylformamide",
        "N,N-dimethylformamide"@nl-be ;
    schema1:alternateName "DMF" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:17741>,
        <https://identifiers.org/cas:68-12-2> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dmf" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "aprotic solvents" .

