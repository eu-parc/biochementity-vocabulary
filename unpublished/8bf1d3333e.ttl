@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8bf1d3333e> a owl:Class ;
    rdfs:label "Linear 6:2 polyfluoroalkyl phosphoric acid monoesters",
        "Lineair 6:2 fluortelomeerfosfaat monoester"@nl-be ;
    schema1:alternateName "3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluorooctyl dihydrogen phosphate",
        "6:2 monoPAP",
        "6:2 monoPAP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:83508>,
        <https://identifiers.org/cas:57678-01-0>,
        <https://identifiers.org/inchikey:FZTRDYSPWWJCOF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:14250578> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "sixmonopap" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

