@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/e853989f12> a owl:Class ;
    rdfs:label "Syn-dechlorane plus",
        "Syn-dechlorane plus"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_79314> ;
    schema1:alternateName "Syn-DP" ;
    schema1:comment "comments: * According to google, the INCHIKEY in our DB corresponds to Anti dechlorane plues." ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:UGQQAJOWXNCOPY-MXYLTYEXSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "sdp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" .

