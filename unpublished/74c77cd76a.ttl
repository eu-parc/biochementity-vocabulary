@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/74c77cd76a> a owl:Class ;
    rdfs:label "9-hydroxyfluorene",
        "9-hydroxyfluoreen"@nl-be ;
    schema1:alternateName "9-FLUO",
        "Fluoren-9-ol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:16904>,
        <https://identifiers.org/cas:1689-64-1>,
        <https://identifiers.org/inchikey:AFMVESZOYKHDBJ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:74318> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ninehfluo" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/463f0f2df8> .

