        <https://identifiers.org/inchikey:RMIODHQZRUFFFF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:12251> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "maa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "glycol ethers" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/38ed851d16>,
