    rdfs:label "Linear Perfluorbutanesulfonylamide(N-methyl)acetate",
        "Lineair N-methylperfluor-n-butaansulfonylamide azijnzuur"@nl-be ;
    schema1:alternateName "MePFBSAA",
        "N-Methyl-N-((perfluorobutyl)sulfonyl)glycine",
        "MePFBSAA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:159381-10-9>,
        <https://identifiers.org/inchikey:SKGBGOQHXBAKKO-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:22286935> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mepfbsaa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

