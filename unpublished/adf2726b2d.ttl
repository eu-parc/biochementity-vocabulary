@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/adf2726b2d> a owl:Class ;
    rdfs:label "Ethylparaben",
        "Ethylparabeen"@nl-be ;
    schema1:alternateName "EtP",
        "Ethyl 4-hydroxybenzoate",
        "EtP"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND6Q9907FMD4GPNFWX>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:31575>,
        <https://identifiers.org/cas:120-47-8>,
        <https://identifiers.org/inchikey:NUVBSKCKDOMJSU-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:8434> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "etpar" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "parabens" .

