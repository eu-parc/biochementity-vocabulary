@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/0f3cacf8fc> a owl:Class ;
    rdfs:label "2-hydroxy atrazine",
        "2-hydroxyatrazine"@nl-be ;
    schema1:alternateName "2-hydroxy atrazine" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:18316>,
        <https://identifiers.org/cas:2163-68-0>,
        <https://identifiers.org/inchikey:NFMIMWNQWAWNDW-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:135398733> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ha2" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "herbicides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/0df789fdea> .

