@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/3e96f71e4c> a owl:Class ;
    rdfs:label "Zearalenone-14-sulphate",
        "Zearalenon-14-sulfaat"@nl-be ;
    schema1:alternateName "ZEN-14-S" ;
    schema1:comment """comments: I only find Zearalenone-4-sulphate (https://pubchem.ncbi.nlm.nih.gov/compound/Zearalenone-4-sulfate)

The INCHIKEY in our DB gives me 0 results in google…""" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:QERXYCPQYWGNFX-XQAKIGHYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "zensulf" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/567b9e5017> .

