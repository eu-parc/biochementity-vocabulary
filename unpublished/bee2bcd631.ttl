@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/bee2bcd631> a owl:Class ;
    rdfs:label "Ethylenebisdithiocarbamates",
        "Ethyleenbisdithiocarbamaten"@nl-be ;
    schema1:alternateName "EBDCs" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:QRNATDQRFAUDKF-UHFFFAOYSA-N> ;
    pehterms:hasGroupLabel "carbamate pesticides",
        "pesticides" .

