<https://w3id.org/peh/biochementities/31568a0fdd> a owl:Class ;
    rdfs:label "Benzylparaben",
        "Benzylparaben"@nl-be ;
    schema1:alternateName "Benzyl 4-Hydroxybenzoate",
        "Benzylparaben" ;
