@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/a66f6d84b3> a owl:Class ;
    rdfs:label "Mono(2-propyl-6-carboxyhexyl) phthalate",
        "Mono(2-propyl-6-carboxyhexyl)ftalaat"@nl-be ;
    schema1:alternateName "Cx-MPHxP",
        "Cx-MPHxP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:1412411-10-9>,
        <https://identifiers.org/inchikey:DPQMLPCFIOCYFY-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:139036037> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "cxmphxp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/527f5ba7b6> .

