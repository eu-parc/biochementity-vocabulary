@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/0414e57c6a> a owl:Class ;
    rdfs:label "Progesterone",
        "Progesteron"@nl-be ;
    schema1:alternateName "Progesterone" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:17026>,
        <https://identifiers.org/pubchem.compound:5994>,
        <https://loinc.org/LP14041-5> .

