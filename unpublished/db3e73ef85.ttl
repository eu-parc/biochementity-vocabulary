@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/db3e73ef85> a owl:Class ;
    rdfs:label "2,4,6-trichlorophenol",
        "2,4,6-trichloorfenol"@nl-be ;
    schema1:alternateName "2,4,6-TCP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:28755>,
        <https://identifiers.org/cas:88-06-2>,
        <https://identifiers.org/inchikey:LINPIYWFGCPVIE-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:6914> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "tcp246" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/3481d765c8>,
        <https://w3id.org/peh/biochementities/cdd86cd306> .

