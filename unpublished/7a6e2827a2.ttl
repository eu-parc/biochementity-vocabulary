@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/7a6e2827a2> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 199",
        "Polychloorbifenyl 199"@nl-be ;
    schema1:alternateName "2,2',3,3',4,5,5',6'-Octachlorobiphenyl",
        "PCB 199",
        "PCB 199"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:52663-75-9>,
        <https://identifiers.org/inchikey:HJBYDWKNARZTMJ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:40482> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb199" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

