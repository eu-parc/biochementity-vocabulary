@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/4ab84d5104> a owl:Class ;
    rdfs:label "Linear Perfluorotridecanesulfonic acid",
        "Lineair Perfluoro-n-tridecaansulfonzuur"@nl-be ;
    schema1:alternateName "PFTrDS",
        "PFTrDS"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:791563-89-8>,
        <https://identifiers.org/inchikey:JMIXTHMPTMXARZ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:21964789> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pftrds" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

