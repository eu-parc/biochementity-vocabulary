@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/72ac0e61e7> a owl:Class ;
    rdfs:label "6-OH-mono-propyl-heptyl phthalate",
        "6-OH-Mono-propyl-heptyl ftalaat"@nl-be ;
    schema1:alternateName "OH-MPHP",
        "6-OH-MPHP"@nl-be ;
    schema1:comment "comments: Structurally defined hydroxy metabolite (6-OH-mono-propyl-heptyl phthalate), selectively measured by GC-HRMS and specific for DPHP metabolism." ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:KNDRVUYMYPIFIU-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:131668311> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ohmphp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/527f5ba7b6> .

