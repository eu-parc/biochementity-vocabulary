<https://w3id.org/peh/biochementities/d5a07e5646> a owl:Class ;
    rdfs:label "Anti-dechlorane plus",
        "Anti-dechloraan plus"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_79314> ;
    schema1:alternateName "Anti-DP" ;
    schema1:comment "comments: * Found this link: https://www.lgcstandards.com/PL/en/Anti-Dechlorane-plus/p/TRC-D226635 that directs me to a CAS number that directs me to this PUBCHEM link: https://pubchem.ncbi.nlm.nih.gov/compound/Dechlorane-Plus --> however this does not match the INCHYKEY already in our DB (for which I found nothing online...)" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:UGQQAJOWXNCOPY-VBCJEVMVSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "adp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" .

