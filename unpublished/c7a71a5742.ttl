@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/c7a71a5742> a owl:Class ;
    rdfs:label "4-Nitrophenol",
        "4-Nitrofenol"@nl-be ;
    schema1:alternateName "4-nitrophenol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:16836>,
        <https://identifiers.org/cas:100-02-7>,
        <https://identifiers.org/inchikey:BTJIUGUIPKRLHP-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:980> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "niphen" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/7814b59232> .

