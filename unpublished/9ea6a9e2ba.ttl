@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/9ea6a9e2ba> a owl:Class ;
    rdfs:label "2-Isopropoxyphenol",
        "2-Isopropoxyfenol"@nl-be ;
    schema1:alternateName "IPP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:38547>,
        <https://identifiers.org/cas:28801-34-5>,
        <https://identifiers.org/cas:4812-20-8>,
        <https://identifiers.org/inchikey:ZNCUUYCDKVNVJH-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:20949> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ipp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "carbamate pesticides",
        "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/a746b47bf4> .

