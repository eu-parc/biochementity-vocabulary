@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/e4c0e13662> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 169",
        "Polychloorbifenyl 169"@nl-be ;
    schema1:alternateName "3,3',4,4',5,5'-Hexachlorobiphenyl",
        "PCB 169",
        "PCB 169"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81517>,
        <https://identifiers.org/cas:32774-16-6>,
        <https://identifiers.org/inchikey:ZHLICBPIXDOFFG-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:36231> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb169" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

