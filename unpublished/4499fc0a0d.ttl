@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/4499fc0a0d> a owl:Class ;
    rdfs:label "Benzo[c]phenanthrene",
        "Benzo[c]fenantreen"@nl-be ;
    schema1:alternateName "BcPh" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098NDFVH6VFC2XZ0P18FY>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:82292>,
        <https://identifiers.org/cas:195-19-7>,
        <https://identifiers.org/inchikey:TUAHORSUHVUKBD-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:9136> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "bcph" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" .

