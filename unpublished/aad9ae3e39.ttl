@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/aad9ae3e39> a owl:Class ;
    rdfs:label "1-methylphenanthrene",
        "1-methylfenantreen"@nl-be ;
    schema1:alternateName "1-MP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:35860>,
        <https://identifiers.org/cas:832-69-9>,
        <https://identifiers.org/inchikey:DOWJXOHBNXRUOD-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:13257> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mphe" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/4cda9c8c72> .

