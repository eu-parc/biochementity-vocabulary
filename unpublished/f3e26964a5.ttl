    rdfs:label "Linear N-(Methyl)nonafluorobutanesulfonamide",
        "Lineair N-methylperfluor-n-butaansulfonamide"@nl-be ;
    schema1:alternateName "1,1,2,2,3,3,4,4,4-nonafluoro-N-methylbutane-1-sulfonamide",
        "MePFBSA",
        "MePFBSA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:68298-12-4>,
        <https://identifiers.org/inchikey:GFZPUWKGPNHWHD-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:109968> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mepfbsa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

