@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/9e864f3f3f> a owl:Class ;
    rdfs:label "5-OH-thiabendazole",
        "5-OH-thiabendazool"@nl-be ;
    schema1:alternateName "5-Hydroxythiabendazole",
        "5OH-THIABENDAZOLE" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:948-71-0>,
        <https://identifiers.org/inchikey:VNENJHUOPQAPAT-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:108227> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "fiveohthiabendazole" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/45a9b996df> .

