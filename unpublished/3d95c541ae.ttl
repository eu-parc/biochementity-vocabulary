@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/3d95c541ae> a owl:Class ;
    rdfs:label "Atrazine mercapturate",
        "Atrazine-mercapturaat"@nl-be ;
    schema1:alternateName "Atrazine mercapturate" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:138722-96-0>,
        <https://identifiers.org/inchikey:JYBXBVCDDNBLJW-VIFPVBQESA-N>,
        <https://identifiers.org/pubchem.compound:178512> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "atmer" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "herbicides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/0df789fdea> .

