@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/4569df3bf7> a owl:Class ;
    rdfs:label "β-zearalenol-glucuronide",
        "β-zearalenolglucuronide"@nl-be ;
    schema1:alternateName "β-ZEL-Glc" ;
    schema1:comment """comments: Gertjan, this compoung is repeated with two identifiers!
feedback_epi team: ISSUE""" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "bzelglca" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/567b9e5017> .

