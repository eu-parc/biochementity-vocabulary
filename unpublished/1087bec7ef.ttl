@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/1087bec7ef> a owl:Class ;
    rdfs:label "Ochratoxin A",
        "Ochratoxine A"@nl-be ;
    schema1:alternateName "OTA" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:7719>,
        <https://identifiers.org/cas:303-47-9> ;
    pehterms:hasGroupLabel "mycotoxins" .

