@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/b7a143fe05> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 99",
        "Polychloorbifenyl 99"@nl-be ;
    schema1:alternateName "PCB 99",
        "PCB 99"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:38380-01-7>,
        <https://identifiers.org/inchikey:LMQJBFRGXHMNOX-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:38013> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb99" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

