@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/a4e305ae33> a owl:Class ;
    rdfs:label "Phenanthrene-1,2,3,4-tetrol",
        "Fenantreen-1,2,3,4-tetrol"@nl-be ;
    schema1:alternateName "PHE-tetrol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:MTKRZWWQDYNZRK-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:23056179> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "phetetrol" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/4cda9c8c72> .

