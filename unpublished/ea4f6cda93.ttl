@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/ea4f6cda93> a owl:Class ;
    rdfs:label "4-hydroxyphenyl phenyl phosphate",
        "4-hydroxyphenyl phenyl phosphate"@nl-be ;
    schema1:alternateName "4-HO-DPHP",
        "4-HO-DPHP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:TUBVQVOADJADLU-UHFFFAOYSA-M>,
        <https://identifiers.org/pubchem.compound:21410666> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "fourohdphp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/0b5bee3208> .

