@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/5a8e126c1b> a owl:Class ;
    rdfs:label "Imidacloprid",
        "Imidacloprid"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "Imidacloprid",
        "Imidacloprid"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:39168>,
        <https://identifiers.org/cas:105827-78-9>,
        <https://identifiers.org/cas:138261-41-3>,
        <https://identifiers.org/inchikey:YWTYJOPNNQFBPC-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:86287518> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "imidacloprid" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

