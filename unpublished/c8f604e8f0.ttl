@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/c8f604e8f0> a owl:Class ;
    rdfs:label "Fenpropathrin" ;
    schema1:alternateName "Fenpropathrin" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:39353>,
        <https://identifiers.org/cas:39515-41-8> ;
    pehterms:hasGroupLabel "pesticides",
        "pyrethroid pesticides" .

