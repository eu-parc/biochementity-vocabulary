@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/d2a9c81fb7> a owl:Class ;
    rdfs:label "Chlorpyrifos-methyl-desmethyl",
        "Chlorpyrifos-methyl-desmethyl"@nl-be ;
    schema1:alternateName "Chlorpyrifos-methyl-desmethyl",
        "Chlorpyrifos-methyl-desmethyl"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:DYESOQMZDNCQNZ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:85859588> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "chlormetdes" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/b8b6e0c612> .

