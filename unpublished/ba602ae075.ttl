@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/ba602ae075> a owl:Class ;
    rdfs:label "3-Acetyldeoxynivalenol",
        "3-Acetyldeoxynivalenol"@nl-be ;
    schema1:alternateName "3-ADON" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:146195>,
        <https://identifiers.org/cas:50722-38-8>,
        <https://identifiers.org/inchikey:ADFIQZBYNGPCGY-HTJQZXIKSA-N>,
        <https://identifiers.org/pubchem.compound:5458510> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "tacetyldon" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/56872ff940> .

