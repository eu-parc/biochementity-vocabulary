@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/ef842d0cbf> a owl:Class ;
    rdfs:label "Linear Perfluorooctadecanoic acid",
        "Lineair Perfluoro-n-octadecaanzuur"@nl-be ;
    schema1:alternateName "PFODA",
        "PFODA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:16517-11-6>,
        <https://identifiers.org/cas:798556-82-8>,
        <https://identifiers.org/inchikey:ZTSDOGSKTICNPQ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:167547> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfoda" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

