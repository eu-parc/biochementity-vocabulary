@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/peh/biochementities/f41f34e1b2> a owl:Class ;
    rdfs:label "3-Aminobiphenyl",
        "3-Aminobifenyl"@nl-be ;
    schema1:alternateName "3ABPH" ;
    schema1:comment "comments: * This one has two CAS numbers according to PUBCHEM --> How to handle this?" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND3BTCXN6EEBJ8TRXB>,
        pehterms:BioChemEntity ;
    skos:exactMatch "https://identifiers.org/cas:2243-47-2"^^xsd:anyURI,
        "https://identifiers.org/cas:41674-04-8"^^xsd:anyURI,
        "https://identifiers.org/inchikey:MUNOBADFTHUUFG-UHFFFAOYSA-N"^^xsd:anyURI,
        "https://identifiers.org/pubchem.compound:16717"^^xsd:anyURI ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "threeabph" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] .

