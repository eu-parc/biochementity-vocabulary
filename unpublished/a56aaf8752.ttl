@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/a56aaf8752> a owl:Class ;
    rdfs:label "Chrysene",
        "Chryseen"@nl-be ;
    schema1:alternateName "CRY",
        "PAK_CHR"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098NDFVH6VFC2XZ0P18FY>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:51687>,
        <https://identifiers.org/cas:218-01-9>,
        <https://identifiers.org/cas:65777-08-4>,
        <https://identifiers.org/inchikey:WDECIBYCCFPHNR-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:9171> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "cry" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" .

