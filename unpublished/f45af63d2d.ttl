<https://w3id.org/peh/biochementities/f45af63d2d> a owl:Class ;
    rdfs:label "Mono(2-ethylhexyl) phthalate",
        "Mono-2-ethylhexyl ftalaat"@nl-be ;
    schema1:alternateName "MEHP",
        "MEHP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity,
