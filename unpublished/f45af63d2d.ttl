    skos:exactMatch <https://identifiers.org/CHEBI:17243>,
        <https://identifiers.org/cas:1276197-22-8>,
        <https://identifiers.org/cas:4376-20-9>,
        <https://identifiers.org/inchikey:DJDSLBVSSOQSLW-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:20393> ;
