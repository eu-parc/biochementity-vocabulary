@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/f63f01f6cb> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 74",
        "Polychloorbifenyl 74"@nl-be ;
    schema1:alternateName "PCB 74",
        "PCB 74"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:32690-93-0>,
        <https://identifiers.org/inchikey:TULCXSBAPHCWCF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:36218> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb74" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

