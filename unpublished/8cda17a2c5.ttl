@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/8cda17a2c5> a owl:Class ;
    rdfs:label "Hydroxylated Polychlorinated biphenyl 187",
        "CB187"@nl-be ;
    schema1:alternateName "Hydroxylated Polychlorinated biphenyl 187",
        "CB187"@nl-be ;
    schema1:comment "comments: Can it be this compound? http://exposome-explorer.iarc.fr/compounds/1308  --> the IUPAC name appears to be a synonym of https://pubchem.ncbi.nlm.nih.gov/compound/178007" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "hocb187" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" .

