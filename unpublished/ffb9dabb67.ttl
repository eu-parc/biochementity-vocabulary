@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/ffb9dabb67> a owl:Class ;
    rdfs:label "Bis(2-butoxyethyl) phosphate",
        "Bis-2-butoxyethyl-fosfaat"@nl-be ;
    schema1:alternateName "BBOEP",
        "BBOEP"@nl-be ;
    schema1:comment "comments: * The INCHIKEY in our DB directs me to this pubchem link: https://pubchem.ncbi.nlm.nih.gov/compound/84299" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:NNXWIPHZHATIFE-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "bboephr" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/0fecddb08c> .

