<https://w3id.org/peh/biochementities/6d39ef56c8> a owl:Class ;
    rdfs:label "Para-Fluoroaniline",
        "Para-fluoraniline"@nl-be ;
    schema1:alternateName "4-Fluoroaniline",
        "para-FA" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND3BTCXN6EEBJ8TRXB>,
        pehterms:BioChemEntity ;
