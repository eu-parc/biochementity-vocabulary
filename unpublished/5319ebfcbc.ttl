@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/5319ebfcbc> a owl:Class ;
    rdfs:label "Linear Perfluorotetradecanoic acid",
        "Lineair Perfluoro-n-tetradecaanzuur"@nl-be ;
    schema1:alternateName "lpfteda",
        "PFTeDA"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/48f3da1e6e>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:376-06-7>,
        <https://identifiers.org/inchikey:RUDINRUXCKIXAJ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:67822> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfteda" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" ;
    pehterms:isIsomerOf <https://w3id.org/peh/biochementities/01KT6EDSFQTR417N1HNCXDET27> .

