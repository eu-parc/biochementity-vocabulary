@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/c337d566af> a owl:Class ;
    rdfs:label "Dimethyl dithiophosphate",
        "Dimethyldithiophosphate"@nl-be ;
    schema1:alternateName "DMDTP",
        "DMDTP"@nl-be ;
    schema1:comment "comments: I'm not sure if this is this compound https://pubchem.ncbi.nlm.nih.gov/compound/S_S-Dimethyl-hydrogen-phosphorodithioate#section=DSSTox-Substance-ID or this one:https://pubchem.ncbi.nlm.nih.gov/compound/dimethyldithiophosphate" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:189748> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dmdtp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/2b58958011>,
        <https://w3id.org/peh/biochementities/d87edc1c36> .

