@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/c530c3b9f9> a owl:Class ;
    rdfs:label "1-,2-dihydroxynaphthalene",
        "1-,2-dihydroxynaftaleen"@nl-be ;
    schema1:alternateName "1,2-NAPH" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:17435>,
        <https://identifiers.org/cas:574-00-5>,
        <https://identifiers.org/inchikey:NXPPAOGUKPJVDI-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:11318> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "diohnap" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/8237ef77e3> .

