@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/463f0f2df8> a owl:Class ;
    rdfs:label "Fluorene",
        "Fluoreen"@nl-be ;
    schema1:alternateName "FLUO",
        "PAK_FLU"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098NDFVH6VFC2XZ0P18FY>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:28266>,
        <https://identifiers.org/cas:86-73-7>,
        <https://identifiers.org/inchikey:NIHNNTQXNPWCJQ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:6853> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "fluo" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" .

