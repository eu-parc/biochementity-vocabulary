@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/464bc16342> a owl:Class ;
    rdfs:label "3-hydroxyfluorene",
        "3-hydroxyfluoreen"@nl-be ;
    schema1:alternateName "3-FLUO" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:89645>,
        <https://identifiers.org/cas:6344-67-8>,
        <https://identifiers.org/inchikey:PVUBSZGNXLNTLX-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:96088> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "threehfluo" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/463f0f2df8> .

