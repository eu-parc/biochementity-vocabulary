@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8d4d7019cc> a owl:Class ;
    rdfs:label "3-hydroxybenz[a]anthracene",
        "3-hydroxybenz[a]antraceen"@nl-be ;
    schema1:alternateName "3-BaA" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:4834-35-9>,
        <https://identifiers.org/inchikey:MRRWKFVZIOCJBS-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:115265> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "hbaa3" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/6699c81fb5> .

