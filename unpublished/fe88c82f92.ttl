@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/fe88c82f92> a owl:Class ;
    rdfs:label "2-hydroxyfluorene",
        "2-hydroxyfluoreen"@nl-be ;
    schema1:alternateName "2-FLUO" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34289>,
        <https://identifiers.org/cas:2443-58-5>,
        <https://identifiers.org/inchikey:ZDOIAPGLORMKTR-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:75547> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "twohfluo" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/463f0f2df8> .

