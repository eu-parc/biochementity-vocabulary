@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/86823d9b21> a owl:Class ;
    rdfs:label "Brain-Derived Neurotrophic Factor" ;
    schema1:alternateName "ANON2",
        "BDNF",
        "BULN2",
        "Brain-derived neurotrophic factor",
        "bdnf",
        "brain derived neurotrophic factor" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/mesh:D019208>,
        <https://identifiers.org/uniprot:P23560> .

