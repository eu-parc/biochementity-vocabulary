<https://w3id.org/peh/biochementities/c2c62fef8c> a owl:Class ;
    rdfs:label "Linear 1H,1H,2H,2H-Perfluorohexanesulfonic acid",
        "Lineair 4:2 fluortelomeersulfonzuur"@nl-be ;
    schema1:alternateName "4:2 FTS",
        "4:2 Fluorotelomer sulfonic acid",
        "4:2 FTS"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:757124-72-4>,
        <https://identifiers.org/inchikey:TXGIGTRUEITPSC-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:20734543> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "fourfts" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

