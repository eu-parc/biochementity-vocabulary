@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/bda1ebe5ab> a owl:Class ;
    rdfs:label "Ethylenethiourea",
        "Ethyleenthioureum"@nl-be ;
    schema1:alternateName "ETU",
        "ETU"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34750>,
        <https://identifiers.org/cas:96-45-7>,
        <https://identifiers.org/inchikey:PDQAZBWRQCGBEV-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:2723650> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "etu" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "carbamate pesticides",
        "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/bee2bcd631> .

