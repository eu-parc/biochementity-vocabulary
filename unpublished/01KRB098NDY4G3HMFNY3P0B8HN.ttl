@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/01KRB098NDY4G3HMFNY3P0B8HN> a owl:Class ;
    rdfs:label "per-/poly-fluorinated compounds" ;
    schema1:alternateName "PFASs" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <CHEBI:172397>,
        <CHEBI:172406> ;
    pehterms:hasGroupLabel "per-/poly-fluorinated compounds" .

