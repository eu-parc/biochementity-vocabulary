@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/61bca12cd7> a owl:Class ;
    rdfs:label "Linear Trifluoroacetic acid",
        "Lineair Trifluoro azijnzuur"@nl-be ;
    schema1:alternateName "TFA",
        "TFA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:45892>,
        <https://identifiers.org/cas:599-00-8>,
        <https://identifiers.org/cas:76-05-1>,
        <https://identifiers.org/inchikey:DTQVDTLACAAQTR-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:6422> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "tfa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

