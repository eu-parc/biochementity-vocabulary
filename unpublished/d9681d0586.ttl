@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/d9681d0586> a owl:Class ;
    rdfs:label "Anthracene",
        "Antraceen"@nl-be ;
    schema1:alternateName "AN" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098NDFVH6VFC2XZ0P18FY>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:35298>,
        <https://identifiers.org/cas:120-12-7>,
        <https://identifiers.org/cas:54261-80-2>,
        <https://identifiers.org/inchikey:MWPLVEDNUUSJAV-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:8418> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "an" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" .

