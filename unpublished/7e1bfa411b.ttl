@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/7e1bfa411b> a owl:Class ;
    rdfs:label "Benzo[e]pyrene",
        "Benzo[e]pyreen"@nl-be ;
    schema1:alternateName "BeP" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098NDFVH6VFC2XZ0P18FY>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34567>,
        <https://identifiers.org/cas:192-97-2>,
        <https://identifiers.org/cas:73467-76-2>,
        <https://identifiers.org/inchikey:TXVHTIQJNYSSKO-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:9128> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "bep" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" .

