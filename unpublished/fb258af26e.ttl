<https://w3id.org/peh/biochementities/fb258af26e> a owl:Class ;
    rdfs:label "N-Phenylacetamide",
        "N-Phenylacetamide"@nl-be ;
    schema1:alternateName "ACA",
        "Acetanilide" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND3BTCXN6EEBJ8TRXB>,
        pehterms:BioChemEntity ;
    skos:exactMatch "https://identifiers.org/CHEBI:28884"^^xsd:anyURI,
        "https://identifiers.org/cas:103-84-4"^^xsd:anyURI,
        "https://identifiers.org/inchikey:FZERHIULMFGESH-UHFFFAOYSA-N"^^xsd:anyURI,
        "https://identifiers.org/pubchem.compound:904"^^xsd:anyURI ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "aca" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] .

