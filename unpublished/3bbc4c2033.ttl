@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/3bbc4c2033> a owl:Class ;
    rdfs:label "Mono-ethyl phthalate",
        "Mono-ethyl ftalaat"@nl-be ;
    schema1:alternateName "MEP",
        "MEP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:70973>,
        <https://identifiers.org/cas:2306-33-4>,
        <https://identifiers.org/inchikey:YWWHKOHZGJFMIE-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:75318> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mep" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/c1911af20b> .

