@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/49f6df1ab9> a owl:Class ;
    rdfs:label "Tebuconazole-OH (hydroxytebuconazole)",
        "Tebuconazool-OH (hydroxytebuconazool)"@nl-be ;
    schema1:alternateName "OH-TEBUCONAZOLE" ;
    schema1:comment "comments: It seems to be a metabolite of this compound https://pubchem.ncbi.nlm.nih.gov/compound/Tebuconazole and this company seems to have a CAS number for it: https://www.schd-shimadzu.com/en/metabolites/2726-167445-Hydroxy-tebuconazole.html but then I also find that CAS number for this other company's compound https://www.lgcstandards.com/LB/en/search?text=212267-64-6" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "tebuconazoleoh" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/3755d13c91> .

