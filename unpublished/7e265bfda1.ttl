<https://w3id.org/peh/biochementities/7e265bfda1> a owl:Class ;
    rdfs:label "2-(2-methoxyethoxy)acetic acid",
        "2-(2-methoxyethoxy)azijnzuur"@nl-be ;
    schema1:alternateName "(2-Methoxyethoxy)acetic acid",
        "MEAA" ;
