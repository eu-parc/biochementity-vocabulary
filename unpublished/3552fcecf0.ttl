@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/3552fcecf0> a owl:Class ;
    rdfs:label "3-Hydroxyfluoranthène",
        "3-Hydroxyfluorantheen"@nl-be ;
    schema1:alternateName "3-OHFA",
        "Fluoranthen-3-ol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:17798-09-3>,
        <https://identifiers.org/inchikey:PQWYZWVBXAOHOU-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:176953> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "threeohfa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" .

