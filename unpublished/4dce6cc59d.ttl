@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/4dce6cc59d> a owl:Class ;
    rdfs:label "Chlorpyrifos-oxon",
        "Chloorpyrifos-oxon"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "chlorpyrifos-oxon" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:5598-15-2>,
        <https://identifiers.org/inchikey:OTMOUPHCTWPNSL-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:21804> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "chlorox" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

