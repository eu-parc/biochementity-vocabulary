@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/63264f2ef3> a owl:Class ;
    rdfs:label "2-(N-Methylperfluorooctanesulfonamido)acetic acid",
        "Lineair + vertakt 2-(n-methylperfluorooctaansulfonamido) azijnzuur"@nl-be ;
    schema1:alternateName "MePFOSAA",
        "L+B MePFOSAA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "lbnmepfosaa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

