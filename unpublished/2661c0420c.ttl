@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/2661c0420c> a owl:Class ;
    rdfs:label "Mono(2-carboxymethylhexyl) phthalate",
        "Mono(2-carboxymethylhexyl)ftalaat"@nl-be ;
    schema1:alternateName "MCMHP",
        "MCMHP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:132874>,
        <https://identifiers.org/cas:82975-93-7>,
        <https://identifiers.org/inchikey:CCNOZWPVQWCJFK-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:187353> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mcmhp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/95e3fd49d0> .

