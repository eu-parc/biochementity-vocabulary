<https://w3id.org/peh/biochementities/ddc69d562e> a owl:Class ;
    rdfs:label "Simazine",
        "Simazine"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_24527> ;
    schema1:alternateName "Simazine" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:27496>,
        <https://identifiers.org/cas:122-34-9>,
        <https://identifiers.org/inchikey:ODCWYMIRDDJXKW-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:5216> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "simz" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "herbicides" .

