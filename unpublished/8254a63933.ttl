@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8254a63933> a owl:Class ;
    rdfs:label "Mono-n-octyl phthalate",
        "Mono-n-octylftalaat"@nl-be ;
    schema1:alternateName "MnOP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:132583>,
        <https://identifiers.org/cas:5393-19-1>,
        <https://identifiers.org/inchikey:PKIYFBICNICNGJ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:79362> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mop" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/ef94d1bbcb> .

