@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/37340efd2b> a owl:Class ;
    rdfs:label "Desethyl desisopropyl atrazine",
        "Desethyl desisopropyl atrazine"@nl-be ;
    schema1:alternateName "Desethyl desisopropyl atrazine" ;
    schema1:comment """comments: The INCHIKEY in our DB directed me to https://pubchem.ncbi.nlm.nih.gov/compound/2%2C4-diamino-6-chloro-s-triazine --> to double check that it is the same compound? 
Also found this: https://pubchem.ncbi.nlm.nih.gov/substance/363592869#section=Source""" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:FVFVNNKYKYZTJU-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "desdesisoat" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "herbicides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/0df789fdea> .

