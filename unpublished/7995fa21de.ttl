@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/7995fa21de> a owl:Class ;
    rdfs:label "Di-isopropyl phosphate",
        "Di-isopropylfosfaat"@nl-be ;
    schema1:alternateName "Di-isopropyl phosphate" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:16785>,
        <https://identifiers.org/cas:1611-31-0>,
        <https://identifiers.org/inchikey:WZPMZMCZAGFKOC-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:74162> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dipp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] .

