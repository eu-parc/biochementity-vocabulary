@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/7925828630> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 128",
        "Polychloorbifenyl 128"@nl-be ;
    schema1:alternateName "PCB 128",
        "PCB 128"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:11096-82-5>,
        <https://identifiers.org/cas:38380-07-3>,
        <https://identifiers.org/inchikey:BTAGRXWGMYTPBY-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:38018> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb128" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

