@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/567b9e5017> a owl:Class ;
    rdfs:label "Zearalenone",
        "Zearalenon"@nl-be ;
    schema1:alternateName "ZEN" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:10106>,
        <https://identifiers.org/cas:17924-92-4> ;
    pehterms:hasGroupLabel "mycotoxins" .

