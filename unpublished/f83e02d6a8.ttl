@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/f83e02d6a8> a owl:Class ;
    rdfs:label "Chlorpyrifos",
        "Chloorpyrifos"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "chlorpyrifos" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34631>,
        <https://identifiers.org/cas:2921-88-2>,
        <https://identifiers.org/inchikey:SBPBAQFWLVIOKP-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:2730> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "chlorpyr" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

