@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/a74bd30e16> a owl:Class ;
    rdfs:label "Butyl benzyl phthalate",
        "Butylbenzylftalaat"@nl-be ;
    schema1:alternateName "BBP",
        "BBP"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND3W1PTM3655D42ZRS>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34595>,
        <https://identifiers.org/cas:85-68-7>,
        <https://identifiers.org/inchikey:IRIAEXORFWYRCZ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:2347> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "bbp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" .

