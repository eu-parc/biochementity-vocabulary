@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/5e0484e089> a owl:Class ;
    rdfs:label "Benzophenone 8",
        "Benzofenon 8"@nl-be ;
    schema1:alternateName "BP-8",
        "BP-8"@nl-be ;
    schema1:comment "source: 2,2'-Dihydroxy-4-methoxybenzophenone" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34208>,
        <https://identifiers.org/cas:131-53-3>,
        <https://identifiers.org/inchikey:MEZZCSHVIGVWFI-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:8569> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dhmb" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "benzophenones",
        "uv filters" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/1d33716ea1> .

