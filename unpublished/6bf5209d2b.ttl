@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/6bf5209d2b> a owl:Class ;
    rdfs:label "Linear Perfluorooctanoic acid",
        "Lineair Perfluoro-n-octaanzuur"@nl-be ;
    schema1:alternateName "lpfoa",
        "PFOA"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/fb91d8f77d>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:35549>,
        <https://identifiers.org/cas:335-67-1>,
        <https://identifiers.org/inchikey:SNGREZUHAYWORS-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:9554> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfoa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" ;
    pehterms:isIsomerOf <https://w3id.org/peh/biochementities/01KT6EDSFQ79JXYPS0NAEQXQH4> .

