@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8ef76a2b2e> a owl:Class ;
    rdfs:label "Cis-chlordane",
        "Cis-chlordane"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "alpha-chlordane",
        "α-chlordane" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:39068>,
        <https://identifiers.org/cas:5103-71-9>,
        <https://identifiers.org/inchikey:BIWJNBZANLAXMG-IDTQJTQFSA-N>,
        <https://identifiers.org/pubchem.compound:12303035> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "achlor" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds",
        "pesticides" .

