@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/1eba3b0d76> a owl:Class ;
    rdfs:label "4-chlorophenol",
        "4-chloorfenol"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "4-MCP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:28078>,
        <https://identifiers.org/cas:106-48-9>,
        <https://identifiers.org/inchikey:WXNZTHHGJRFXKQ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:4684> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mcp4" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

