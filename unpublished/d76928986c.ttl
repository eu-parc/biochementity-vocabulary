<https://w3id.org/peh/biochementities/d76928986c> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 118",
        "Polychloorbifenyl 118"@nl-be ;
    schema1:alternateName "2,3',4,4',5-Pentachlorobiphenyl",
        "PCB 118",
        "PCB 118"@nl-be ;
