@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/0df789fdea> a owl:Class ;
    rdfs:label "Atrazine",
        "Atrazine"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_24527> ;
    schema1:alternateName "Atrazine" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:15930>,
        <https://identifiers.org/cas:1912-24-9>,
        <https://identifiers.org/inchikey:MXWJVTOOROXGIU-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:2256> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "atrz" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "herbicides" .

