@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/63e119fc83> a owl:Class ;
    rdfs:label "Linear Perfluorobutanoic acid",
        "Lineair Perfluoro-n-butaanzuur"@nl-be ;
    schema1:alternateName "Heptafluorobutyric acid",
        "PFBA",
        "PFBA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity,
        <https://w3id.org/peh/biochementities/a85dc0f98d> ;
    skos:exactMatch <https://identifiers.org/CHEBI:39426>,
        <https://identifiers.org/cas:375-22-4>,
        <https://identifiers.org/inchikey:YPJUNDFVDDCYIH-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:9777> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfba" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

