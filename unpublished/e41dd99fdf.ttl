    rdfs:label "3-OH-Mono-n-butyl phthalate",
        "3-OH-mono-n-butylftalaat"@nl-be ;
    schema1:alternateName "Mono-hydroxy-n-butyl",
        "OH-MnBP",
        "acid",
        "phthalate|2-[(3-hydroxybutoxy)carbonyl]benzoic" ;
    schema1:comment "source: http://exposome-explorer.iarc.fr/compounds/1507" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND3W1PTM3655D42ZRS>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:CTDCWBUTXCPHAM-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ohmnbp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "aprotic solvents",
        "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/ca6f875372> .
