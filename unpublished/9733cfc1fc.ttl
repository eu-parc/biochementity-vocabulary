@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/9733cfc1fc> a owl:Class ;
    rdfs:label "2-phenoxyacetic acid",
        "2-fenoxyazijnzuur"@nl-be ;
    schema1:alternateName "PhAA",
        "Phenoxyacetic Acid" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:8075>,
        <https://identifiers.org/cas:122-59-8>,
        <https://identifiers.org/inchikey:LCPDWSOZIOUXRV-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:19188> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "phaa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "glycol ethers" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/e6bc9a1d56> .

