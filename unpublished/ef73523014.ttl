<https://w3id.org/peh/biochementities/ef73523014> a owl:Class ;
    rdfs:label "T-2 triol toxin",
        "T-2 trioltoxine"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25442> ;
    schema1:alternateName "T-2 triol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:34114-98-2>,
        <https://identifiers.org/inchikey:DDAUKBBLCGQHIP-CAVDVMKYSA-N>,
        <https://identifiers.org/pubchem.compound:13797589> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ttriol" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" .

