@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/4c162442ef> a owl:Class ;
    rdfs:label "Cyclopenta[c,d]pyrene",
        "Cyclopenta[c,d]pyreen"@nl-be ;
    schema1:alternateName "CPP" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098NDFVH6VFC2XZ0P18FY>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:82279>,
        <https://identifiers.org/cas:27208-37-3>,
        <https://identifiers.org/inchikey:BZCXQYVNASLLQO-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:33743> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "cpp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" .

