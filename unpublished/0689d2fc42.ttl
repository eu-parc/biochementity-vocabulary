@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/0689d2fc42> a owl:Class ;
    rdfs:label "6-Oxo-mono-propyl-heptyl phthalate",
        "6-Oxo-Mono-propyl-heptyl ftalaat (GC-HRMS method, only DPHP metabolites)"@nl-be ;
    schema1:alternateName "oxo-MPHP",
        "6-oxo-MPHP"@nl-be ;
    schema1:comment "comments: Structurally defined oxo metabolite (6-oxo-mono-propyl-heptyl phthalate), selectively measured by GC-HRMS and specific for DPHP metabolism." ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:NSGSMZPMFOBAFF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:131668297> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "oxomphp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/527f5ba7b6> .

