@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/e97d5c58b6> a owl:Class ;
    rdfs:label "Linear Perfluorohexadecanoic acid",
        "Lineair Perfluoro-n-hexadecaanzuur"@nl-be ;
    schema1:alternateName "PFHxDA",
        "PFHxDA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:67905-19-5>,
        <https://identifiers.org/inchikey:OJMBMWRMTMHMSZ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:106027> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfhxda" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

