@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/391bfe09ba> a owl:Class ;
    rdfs:label "Linear Perfluorohexanesulfonamide",
        "Lineair Perfluoro-n-hexaansulfonamide"@nl-be ;
    schema1:alternateName "PFHxSA",
        "PFHxSA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:41997-13-1>,
        <https://identifiers.org/inchikey:WDZLGCSJJWEQJO-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:11603678> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfhxsa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

