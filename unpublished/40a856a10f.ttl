@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/40a856a10f> a owl:Class ;
    rdfs:label "Desisopropyl atrazine",
        "Desisopropylatrazine"@nl-be ;
    schema1:alternateName "Deisopropylatrazine",
        "Desisopropyl atrazine" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:27399>,
        <https://identifiers.org/cas:1007-28-9>,
        <https://identifiers.org/inchikey:IVENSCMCQBJAKW-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:13878> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "desisoat" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "herbicides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/0df789fdea> .

