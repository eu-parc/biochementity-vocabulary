@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/4c223db9b5> a owl:Class ;
    rdfs:label "Dieldrin",
        "Dieldrin"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "dieldrin" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34696>,
        <https://identifiers.org/cas:60-57-1>,
        <https://identifiers.org/inchikey:DFBKLUNHFCTMDC-PICURKEMSA-N>,
        <https://identifiers.org/pubchem.compound:969491> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dieldrin" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

