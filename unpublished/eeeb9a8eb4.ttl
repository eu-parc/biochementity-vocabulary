@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/eeeb9a8eb4> a owl:Class ;
    rdfs:label "Thorium",
        "Thorium"@nl-be ;
    schema1:alternateName "Th",
        "Th"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND4E5V1PY6CGZC1PB9>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:33385>,
        <https://identifiers.org/cas:7440-29-1>,
        <https://identifiers.org/inchikey:ZSLUVFAKFWKJRC-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:23960> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "th" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "metals" .

