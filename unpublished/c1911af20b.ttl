@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/c1911af20b> a owl:Class ;
    rdfs:label "Diethyl phthalate",
        "Diethylftalaat"@nl-be ;
    schema1:alternateName "DEPbis",
        "DEP"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND3W1PTM3655D42ZRS>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34698>,
        <https://identifiers.org/cas:84-66-2>,
        <https://identifiers.org/inchikey:FLKPEMZONWLCSK-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:6781> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "depht" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" .

