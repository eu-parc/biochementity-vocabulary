@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/3ee366213e> a owl:Class ;
    rdfs:label "Ortho-Fluoroaniline",
        "Ortho-fluoraniline"@nl-be ;
    schema1:alternateName "ortho-FA" ;
    schema1:comment "comments: * Can it be this one? https://pubchem.ncbi.nlm.nih.gov/compound/2-Fluoroaniline" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND3BTCXN6EEBJ8TRXB>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:27526>,
        <https://identifiers.org/cas:348-54-9> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ofa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "anilines and MOCA" .

