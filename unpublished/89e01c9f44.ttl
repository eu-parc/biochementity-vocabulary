        "BDE-196"@nl-be ;
    schema1:comment """comments: * Don't find this
feedback_epi team: BDE-196 does not have a parent compound, the compound you are exposed to externally is BDE-196 and it doesn't metabolize to anything elso so we still measure BDE-196 in HBM. so it would have itself as parent compound.""" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:IEWFKOVTVJNWFF-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
