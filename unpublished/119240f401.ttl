@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/119240f401> a owl:Class ;
    rdfs:label "1,2-Dihydroxyphenanthrene",
        "1,2-Dihydroxyfenantreen"@nl-be ;
    schema1:alternateName "1,2-DHPbis" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:37452>,
        <https://identifiers.org/cas:19551-04-3>,
        <https://identifiers.org/inchikey:HNMUTKMLCMUDSB-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:9543118> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "onetwohphe" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/4cda9c8c72> .

