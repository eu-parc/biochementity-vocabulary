@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/f3a2cb6b3d> a owl:Class ;
    rdfs:label "Mono(2,7-methyl-7-carboxy-heptyl) phthalate",
        "Mono(2,7-methyl-7-carboxy-heptyl)ftalaat"@nl-be ;
    schema1:alternateName "cx-MiDP",
        "cx-MiDP"@nl-be ;
    schema1:comment "source: http://exposome-explorer.iarc.fr/compounds/1504" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:RELGYNUSJXUKGN-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "cxmidp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/3b70545c92> .

