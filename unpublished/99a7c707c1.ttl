@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/99a7c707c1> a owl:Class ;
    rdfs:label "Mono-benzyl phthalate",
        "Mono-benzyl ftalaat"@nl-be ;
    schema1:alternateName "MBzP",
        "MBzP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:132612>,
        <https://identifiers.org/cas:2528-16-7>,
        <https://identifiers.org/inchikey:XIKIUQUXDNHBFR-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:31736> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mbzp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/a74bd30e16> .

