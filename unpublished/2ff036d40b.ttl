@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/2ff036d40b> a owl:Class ;
    rdfs:label "Tetrabromoethylcyclohexane",
        "Tetrabroomethylcyclohexaan"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_79314> ;
    schema1:alternateName "TBECH" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:RSNWTYLUIPARFX-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:20472541> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "tbech" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" .

