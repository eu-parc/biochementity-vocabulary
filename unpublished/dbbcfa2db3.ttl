@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/dbbcfa2db3> a owl:Class ;
    rdfs:label "Octabromotrimethylphenylindane",
        "Octabroomtrimethylfenylindaan"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_79314> ;
    schema1:alternateName "OBIND" ;
    schema1:comment "comments: * Did not find the name or the inchi key" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:SNKXRWQAVFAAGH-UHFFFAOYSA-N> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "obind" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" .

