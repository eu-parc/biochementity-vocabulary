@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/77e6d24101> a owl:Class ;
    rdfs:label "1,2-dimethoxyethane",
        "1,2-dimethoxyethaan"@nl-be ;
