@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/2596246b6d> a owl:Class ;
    rdfs:label "Octachlorodibenzodioxin",
        "Octachloordibenzodioxine"@nl-be ;
    schema1:alternateName "OCDD",
        "Octachlorodibenzo-P-dioxin" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND0MXJ7J2ZSF49KSFN>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81566>,
        <https://identifiers.org/cas:3268-87-9>,
        <https://identifiers.org/inchikey:FOIBFBMSLDGNHL-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:18636> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ocdd" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "dioxins" .

