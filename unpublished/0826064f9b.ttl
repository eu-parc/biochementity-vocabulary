@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/0826064f9b> a owl:Class ;
    rdfs:label "Deoxynivalenol-3-glucoside",
        "Deoxynivalenol-3-glucoside"@nl-be ;
    schema1:alternateName "DON-3-glucoside" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:168268>,
        <https://identifiers.org/cas:131180-21-7>,
        <https://identifiers.org/inchikey:PUMXWMGECQIOGB-SMSDQXDJSA-N>,
        <https://identifiers.org/pubchem.compound:71312510> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "domgluc" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/56872ff940> .

