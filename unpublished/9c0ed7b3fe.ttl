@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/9c0ed7b3fe> a owl:Class ;
    rdfs:label "Tributyltin",
        "Tributyltin"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "TBT",
        "Tributylstannanyl" ;
    schema1:comment "comments: Please confirm that Tributylstannanyl and TBT are the same compound, I think they are" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:20763-88-6>,
        <https://identifiers.org/cas:688-73-3>,
        <https://identifiers.org/inchikey:PIILXFBHQILWPS-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:3032732> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "tbt" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

