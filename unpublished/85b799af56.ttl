@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/85b799af56> a owl:Class ;
    rdfs:label "Linear Perfluorooctanesulfonamido acetic acid",
        "Lineair Perfluoro-n-octaansulfonamidoazijnzuur"@nl-be ;
    schema1:alternateName "PFOSAA",
        "PFOSAA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:83505>,
        <https://identifiers.org/cas:2806-24-8>,
        <https://identifiers.org/inchikey:AYLOUUCBACYHAB-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:10507011> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfosaa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

