@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/00fb5fbc05> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 187",
        "Polychloorbifenyl 187"@nl-be ;
    schema1:alternateName "PCB 187",
        "PCB 187"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:52663-68-0>,
        <https://identifiers.org/inchikey:UDMZPLROONOSEF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:40475> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb187" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

