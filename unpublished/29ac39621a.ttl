@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/29ac39621a> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 49",
        "Polychloorbifenyl 49"@nl-be ;
    schema1:alternateName "PCB 49",
        "PCB 49"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:41464-40-8>,
        <https://identifiers.org/inchikey:ZWPVHELAQPIZHO-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:38876> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb49" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

