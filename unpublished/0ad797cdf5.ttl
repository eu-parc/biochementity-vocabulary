        <https://identifiers.org/cas:583-78-8>,
        <https://identifiers.org/inchikey:RANCECPPZPIPNO-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:66> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dcp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/616d17aa41> .

