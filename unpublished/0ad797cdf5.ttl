<https://w3id.org/peh/biochementities/0ad797cdf5> a owl:Class ;
    rdfs:label "2,5-dichlorophenol",
        "2,5-Dichlorophenol"@nl-be ;
    schema1:alternateName "2,5-DCP",
        "2,5-DCP"@nl-be ;
