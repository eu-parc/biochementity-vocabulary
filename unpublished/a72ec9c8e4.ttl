<https://w3id.org/peh/biochementities/a72ec9c8e4> a owl:Class ;
    rdfs:label "Diethyl phosphate",
        "Diethylphosphate"@nl-be ;
    schema1:alternateName "DEP",
        "DEP"@nl-be ;
