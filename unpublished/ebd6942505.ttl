@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/ebd6942505> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 52",
        "Polychloorbifenyl 52"@nl-be ;
    schema1:alternateName "2,2',5,5'-Tetrachlorobiphenyl",
        "PCB 52",
        "PCB 52"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34206>,
        <https://identifiers.org/cas:35693-99-3>,
        <https://identifiers.org/inchikey:HCWZEPKLWVAEOV-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:37248> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb52" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

