@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/97c92a9da2> a owl:Class ;
    rdfs:label "Bis(1-chloro-2-propyl) phosphate",
        "Bis(1-chloro-2-propyl) phosphate"@nl-be ;
    schema1:alternateName "BCIPP",
        "BCIPP"@nl-be ;
    schema1:comment "comments: * THE CHEBI directs me to this pubchem compound: https://pubchem.ncbi.nlm.nih.gov/compound/Bis_2-chloro-1-methylethyl_-hydrogen-phosphate" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:166470> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "bcippms" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/31c3508afe> .

