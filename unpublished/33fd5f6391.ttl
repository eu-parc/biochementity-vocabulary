@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/33fd5f6391> a owl:Class ;
    rdfs:label "Dimethylarsinic",
        "Dimethylarseen"@nl-be ;
    schema1:alternateName "DMA",
        "dimethylarsinic acid",
        "DMA"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:48765>,
        <https://identifiers.org/cas:75-60-5>,
        <https://identifiers.org/cas:917-76-0>,
        <https://identifiers.org/inchikey:OGGXGZAMXPVRFZ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:2513> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dma" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "metals" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/27baf79af9> .

