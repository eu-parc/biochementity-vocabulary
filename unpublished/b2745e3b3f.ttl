@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/b2745e3b3f> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 209",
        "Polychloorbifenyl 209"@nl-be ;
    schema1:alternateName "Decachlorobiphenyl",
        "PCB 209",
        "PCB 209"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34666>,
        <https://identifiers.org/cas:2051-24-3>,
        <https://identifiers.org/inchikey:ONXPZLFXDMAPRO-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:16318> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb209" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

