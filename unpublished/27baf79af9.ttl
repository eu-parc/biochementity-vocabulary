@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/27baf79af9> a owl:Class ;
    rdfs:label "Arsenic",
        "Arseen"@nl-be ;
    schema1:alternateName "As" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND4E5V1PY6CGZC1PB9>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:27563>,
        <https://identifiers.org/cas:7440-38-2>,
        <https://identifiers.org/cas:7784-42-1>,
        <https://identifiers.org/inchikey:RQNWIZPPADIBDY-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:5359596> ;
