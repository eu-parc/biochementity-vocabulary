<https://w3id.org/peh/biochementities/d84be9bac4> a owl:Class ;
    rdfs:label "Cyclohexane-1,2-dicarboxylate-mono-(7-hydroxy-4-methyl)octyl ester",
        "Cyclohexane-1,2-dicarboxylate-mono-(7-hydroxy-4-methyl)octyl ester"@nl-be ;
    schema1:alternateName "2-(7-Hydroxy-4-methyloctoxy)carbonylcyclohexane-1-carboxylic acid",
        "OH-MINCH",
        "OH-MINCH"@nl-be ;
    schema1:comment """comments: * Could not find this anywhere. Could it be this? https://pubchem.ncbi.nlm.nih.gov/compound/155898868
feedback_epi team: Chebi: 166460
Inchikey: WPTRTTWYMWWUTQ-UHFFFAOYSA-N	https://pubchem.ncbi.nlm.nih.gov/compound/102105765
This info was validated by Adrian Covaci before.""" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:166460>,
        <https://identifiers.org/cas:1637562-52-7>,
        <https://identifiers.org/inchikey:RFNYHMLLEAVKHD-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:102105765> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mhnch" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "DINCH" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/cac83ffadf> .

