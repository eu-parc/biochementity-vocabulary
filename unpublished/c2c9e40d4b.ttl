@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/c2c9e40d4b> a owl:Class ;
    rdfs:label "Linear Perfluoropentane sulfonate",
        "Lineair Perfluoro-n-pentaansulfonzuur"@nl-be ;
    schema1:alternateName "PFPeS",
        "PFPeS"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:175905-36-9>,
        <https://identifiers.org/inchikey:ACEKLXZRZOWKRY-UHFFFAOYSA-M>,
        <https://identifiers.org/pubchem.compound:22721493> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfpes" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

