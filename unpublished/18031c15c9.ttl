@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/18031c15c9> a owl:Class ;
    rdfs:label "Cypermethrin" ;
    schema1:alternateName "Cypermethrin" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:4042>,
        <https://identifiers.org/cas:52315-07-8> ;
    pehterms:hasGroupLabel "pesticides",
        "pyrethroid pesticides" .

