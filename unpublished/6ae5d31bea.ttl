@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/6ae5d31bea> a owl:Class ;
    rdfs:label "1-hydroxyphenanthrene",
        "1-hydroxyfenantreen"@nl-be ;
    schema1:alternateName "1-PHEN" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:27528>,
        <https://identifiers.org/cas:2433-56-9>,
        <https://identifiers.org/cas:30774-95-9>,
        <https://identifiers.org/inchikey:GTBXZWADMKOZQJ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:98490> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "onehphe" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/4cda9c8c72> .

