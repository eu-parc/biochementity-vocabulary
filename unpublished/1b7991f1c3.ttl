@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/1b7991f1c3> a owl:Class ;
    rdfs:label "Hydroxylated Polychlorinated biphenyl 107",
        "CB107"@nl-be ;
    schema1:alternateName "Hydroxylated Polychlorinated biphenyl 107",
        "CB107"@nl-be ;
    schema1:comment "comments: Can it be this compound? http://exposome-explorer.iarc.fr/compounds/1306 --> although the INCHI KEY in that website refers me to this compound in pubchem… https://pubchem.ncbi.nlm.nih.gov/compound/2_3_6-trichloro-4-_3_4-dichlorophenyl_phenol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "hocb107" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" .

