@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/35259dcac3> a owl:Class ;
    rdfs:label "Hydroxyphenyl diphenyl phosphate",
        "4-hydroxyphenyl diphenyl phosphate"@nl-be ;
    schema1:alternateName "4-Hydroxyphenyl diphenyl phosphate",
        "HO-TPHP",
        "4-HO-TPHP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:56806-74-7>,
        <https://identifiers.org/inchikey:NOPNBQOZUKISRP-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:57058026> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ohtphp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "flame retardants" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/0b5bee3208> .

