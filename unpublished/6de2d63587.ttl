@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/6de2d63587> a owl:Class ;
    rdfs:label "1-hydroxychrysene",
        "1-hydroxychryseen"@nl-be ;
    schema1:alternateName "1-CRY",
        "1-Chrysenol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:132391>,
        <https://identifiers.org/cas:63019-38-5>,
        <https://identifiers.org/inchikey:ISHBWEUQYFEVES-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:44284> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "onehcry" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/a56aaf8752> .

