    skos:exactMatch <https://identifiers.org/CHEBI:9381>,
        <https://identifiers.org/cas:21259-20-1>,
        <https://identifiers.org/inchikey:BXFOFFBJRFZBQZ-QYWOHJEZSA-N>,
        <https://identifiers.org/pubchem.compound:5284461> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ttwo" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" .

