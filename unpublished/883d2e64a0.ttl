@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/883d2e64a0> a owl:Class ;
    rdfs:label "Simazine mercapturate",
        "Simazine-mercapturaat"@nl-be ;
    schema1:alternateName "Simazine mercapturate" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/inchikey:CSQCJPSBEYLCBK-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:86196119> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "simzmerc" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "herbicides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/ddc69d562e> .

