@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/fea12ccdd3> a owl:Class ;
    rdfs:label "Thyroxine",
        "thyroxine"@nl-be ;
    schema1:alternateName "Thyroxine",
        "Total Thyroxine" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://loinc.org/LP15900-1> .

