@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/d60439fd3f> a owl:Class ;
    rdfs:label "Mono-isobutyl phthalate",
        "Mono-isobutyl ftalaat"@nl-be ;
    schema1:alternateName "MiBP",
        "MiBP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:90038>,
        <https://identifiers.org/cas:30833-53-5>,
        <https://identifiers.org/inchikey:RZJSUWQGFCHNFS-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:92272> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mibp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/72ef88ed5b> .

