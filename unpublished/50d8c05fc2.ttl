@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/50d8c05fc2> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 114",
        "Polychloorbifenyl 114"@nl-be ;
    schema1:alternateName "PCB 114",
        "PCB 114"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81519>,
        <https://identifiers.org/cas:74472-37-0>,
        <https://identifiers.org/inchikey:SXZSFWHOSHAKMN-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:53036> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb114" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

