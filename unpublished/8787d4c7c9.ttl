@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8787d4c7c9> a owl:Class ;
    rdfs:label "Linear Perfluoroundecanesulfonic acid",
        "Lineair Perfluoro-n-undecaansulfonzuur"@nl-be ;
    schema1:alternateName "PFUnDS",
        "PFUnDS"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:749786-16-1>,
        <https://identifiers.org/inchikey:UKHUPOMCGUFNAP-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:22141518> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfunds" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" .

