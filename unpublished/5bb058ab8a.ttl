@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/5bb058ab8a> a owl:Class ;
    rdfs:label "Hydrolysed-fumonisin B1",
        "Gehydrolyseerde fumonisine B1"@nl-be ;
    schema1:alternateName "HFB1" ;
    schema1:comment "comments: I think it's this compound but Anthony to confirm before I add exact_matches: https://pubchem.ncbi.nlm.nih.gov/compound/Aminopentol" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "hfbone" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/d657707232> .

