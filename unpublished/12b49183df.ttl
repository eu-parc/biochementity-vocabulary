@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/12b49183df> a owl:Class ;
    rdfs:label "Dimethyl phosphate",
        "Dimethylphosphate"@nl-be ;
    schema1:alternateName "DMPbis",
        "DMP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:166474>,
        <https://identifiers.org/cas:53396-59-1>,
        <https://identifiers.org/cas:813-78-5>,
        <https://identifiers.org/inchikey:KKUKTXOBAWVSHC-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:13134> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dmp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/2b58958011>,
        <https://w3id.org/peh/biochementities/d87edc1c36> .

