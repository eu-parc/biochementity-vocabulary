@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/01KT9ERZ6BBQMCY2R9A9S2BDV2> a owl:Class ;
    rdfs:label "acyl-CoA dehydrogenase medium chain" ;
    schema1:alternateName "ACADM",
        "MCAD",
        "Medium-chain acyl-CoA dehydrogenase" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <NCBIGene:34> .

