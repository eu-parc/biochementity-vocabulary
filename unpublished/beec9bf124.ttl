@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/beec9bf124> a owl:Class ;
    rdfs:label "Aflatoxin M1",
        "Aflatoxine M1"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25442> ;
    schema1:alternateName "AFM1" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:78576>,
        <https://identifiers.org/cas:6795-23-9>,
        <https://identifiers.org/inchikey:MJBWDEQAUQTVKK-IAGOWNOFSA-N>,
        <https://identifiers.org/pubchem.compound:15558498> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "afm" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" .

