@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/9fa0bb2168> a owl:Class ;
    rdfs:label "Diethyl thiophosphate",
        "Diethylthiophosphate"@nl-be ;
    schema1:alternateName "DETP",
        "DETP"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:156216>,
        <https://identifiers.org/inchikey:PKUWKAXTAVNIJR-UHFFFAOYSA-M>,
        <https://identifiers.org/pubchem.compound:3683036> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "detp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/d98d8688ed> .

