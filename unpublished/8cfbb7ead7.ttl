@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/8cfbb7ead7> a owl:Class ;
    rdfs:label "Mono-cyclo-hexyl phthalate",
        "Mono-cyclo-hexylftalaat"@nl-be ;
    schema1:alternateName "MCHP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:132609>,
        <https://identifiers.org/cas:7517-36-4>,
        <https://identifiers.org/inchikey:PMDKYLLIOLFQPO-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:165618> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mchp" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "phthalates" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/3c60285fb2> .

