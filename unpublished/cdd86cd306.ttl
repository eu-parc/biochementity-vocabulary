@prefix ns1: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/cdd86cd306> a owl:Class ;
    rdfs:label "Hexachlorobenzene",
        "Hexachlorobenzeen"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "HCB",
        "HCB"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:5692>,
        <https://identifiers.org/cas:118-74-1>,
        <https://identifiers.org/inchikey:CKAPSXZOOQJIBF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:8370> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "hcb" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds",
        "pesticides" .

