@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/521377746c> a owl:Class ;
    rdfs:label "3-hydroxybenzo(a)pyrene",
        "3-hydroxybenzo(a)pyreen"@nl-be ;
    schema1:alternateName "3-hydroxyBaP" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34337>,
        <https://identifiers.org/cas:13345-21-6>,
        <https://identifiers.org/inchikey:SPUUWWRWIAEPDB-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:25890> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ohbap" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/ce4c35ea2c> .

