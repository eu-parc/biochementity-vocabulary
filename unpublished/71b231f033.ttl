<https://w3id.org/peh/biochementities/71b231f033> a owl:Class ;
    rdfs:label "Heptylparaben",
        "HeptylP (heptylparabeen)"@nl-be ;
    schema1:alternateName "Heptyl p-hydroxybenzoate",
        "heptylP" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND6Q9907FMD4GPNFWX>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34788>,
        <https://identifiers.org/cas:1085-12-7>,
        <https://identifiers.org/inchikey:ZTJORNVITHUQJA-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:14138> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "hepip" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "parabens" .

