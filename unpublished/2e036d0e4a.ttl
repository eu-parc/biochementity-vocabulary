@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/2e036d0e4a> a owl:Class ;
    rdfs:label "Arsenic(III) acid",
        "Arseen(III)zuur"@nl-be ;
    schema1:alternateName "As(III)",
        "As(III)"@nl-be ;
    schema1:comment """comments: * I don't think the CAS nr in our DB is correct
* For the CHEBI key --> this is the link: https://www.ebi.ac.uk/chebi/CHEBI:35828
* I did not find anything in PUBCHEM?""" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:35828> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "asthree" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "metals" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/27baf79af9> .

