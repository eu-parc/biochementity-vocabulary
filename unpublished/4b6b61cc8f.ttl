@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/4b6b61cc8f> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 195",
        "Polychloorbifenyl 195"@nl-be ;
    schema1:alternateName "2,2',3,3',4,4',5,6-Octachlorobiphenyl",
        "PCB 195",
        "PCB 195"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:31472-83-0>,
        <https://identifiers.org/cas:52663-78-2>,
        <https://identifiers.org/inchikey:JAHJITLFJSDRCG-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:40485> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb195" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

