@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/466598c5fb> a owl:Class ;
    rdfs:label "Desethyl atrazine",
        "Desethylatrazine"@nl-be ;
    schema1:alternateName "Deethylatrazine",
        "Desethyl atrazine" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:28212>,
        <https://identifiers.org/cas:6190-65-4>,
        <https://identifiers.org/inchikey:DFWFIQKMSFGDCQ-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:22563> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "desat" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "herbicides" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/0df789fdea> .

