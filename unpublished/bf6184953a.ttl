@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/bf6184953a> a owl:Class ;
    rdfs:label "Linear Perfluorodecanoic acid",
        "Lineair Perfluoro-n-decaanzuur"@nl-be ;
    schema1:alternateName "lpfda",
        "PFDA"@nl-be ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/d6f3655454>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:35546>,
        <https://identifiers.org/cas:335-76-2>,
        <https://identifiers.org/inchikey:PCIUEQPBYFRTEM-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:9555> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pfda" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "PFAS" ;
    pehterms:isIsomerOf <https://w3id.org/peh/biochementities/01KT6EDSFQTM8JMKBVAERP9DTJ> .

