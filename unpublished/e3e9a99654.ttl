@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/e3e9a99654> a owl:Class ;
    rdfs:label "Methyl mercury",
        "Methylkwik"@nl-be ;
    schema1:alternateName "MeHg",
        "MeHg"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:30785>,
        <https://identifiers.org/cas:16056-34-1>,
        <https://identifiers.org/inchikey:JJWSNOOGIUMOEE-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:7906> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "mhg" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "metals" .

