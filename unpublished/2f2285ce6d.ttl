@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/2f2285ce6d> a owl:Class ;
    rdfs:label "Dibenzo[a,i]pyrene",
        "Dibenzo[a,i]pyreen"@nl-be ;
    schema1:alternateName "DBaiP" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098NDFVH6VFC2XZ0P18FY>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:82314>,
        <https://identifiers.org/cas:189-55-9>,
        <https://identifiers.org/inchikey:TUGYIJVAYAHHHM-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:9106> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dbaip" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" .

