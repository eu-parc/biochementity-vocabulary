<https://w3id.org/peh/biochementities/4da3e66543> a owl:Class ;
    rdfs:label "Aldrin",
        "Aldrin"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "Aldrin" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
