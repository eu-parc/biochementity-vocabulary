        <https://identifiers.org/cas:309-00-2>,
        <https://identifiers.org/inchikey:QBYJBZPUGVGKQQ-SJJAEHHWSA-N>,
        <https://identifiers.org/pubchem.compound:12310947> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "aldrin" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "pesticides" .

