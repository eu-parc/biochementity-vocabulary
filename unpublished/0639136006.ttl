@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/0639136006> a owl:Class ;
    rdfs:label "N-hydroxymethyl-N-methylacetamide",
        "N-hydroxymethyl-N-methylacetamide"@nl-be ;
    schema1:alternateName "DMAC-OH" ;
    schema1:comment "comments: * Is it maybe this  compound? https://pubchem.ncbi.nlm.nih.gov/compound/N-_4-_Hydroxymethyl_phenyl_-N-methylacetamide" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dmacoh" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "aprotic solvents" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/cf5512dcc0> .

