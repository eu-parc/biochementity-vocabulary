@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/cce1717df9> a owl:Class ;
    rdfs:label "2-,6-dimethylnaphthalene",
        "2-,6-dimethylnaftaleen"@nl-be ;
    schema1:alternateName "2-,6-DMN" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34251>,
        <https://identifiers.org/cas:581-42-0>,
        <https://identifiers.org/cas:96789-56-9>,
        <https://identifiers.org/inchikey:YGYNBBAUIYTWBF-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:11387> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "dmnap" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/8237ef77e3> .

