@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/ca97c1bf14> a owl:Class ;
    rdfs:label "Zearalanone",
        "Zearalanon"@nl-be ;
    schema1:alternateName "ZAN" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:35051>,
        <https://identifiers.org/cas:5975-78-0>,
        <https://identifiers.org/inchikey:APJDQUGPCJRQRJ-LBPRGKRZSA-N>,
        <https://identifiers.org/pubchem.compound:108003> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "zan" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "mycotoxins" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/567b9e5017> .

