@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .

<https://w3id.org/peh/biochementities/9c34ebdc76> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl",
        "Polychlorinated biphenyl"@nl-be ;
    schema1:alternateName "PCB",
        "PCB"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    pehterms:hasGroupLabel "organochlorine compounds" .

