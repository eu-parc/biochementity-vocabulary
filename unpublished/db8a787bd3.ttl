@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/db8a787bd3> a owl:Class ;
    rdfs:label "Esfenvalerate",
        "Esfenvaleraat"@nl-be ;
    schema1:alternateName "Esfenvalerate" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:39346>,
        <https://identifiers.org/cas:66230-04-4> ;
    pehterms:hasGroupLabel "pesticides",
        "pyrethroid pesticides" .

