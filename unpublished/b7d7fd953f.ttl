@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pehterms: <https://w3id.org/peh/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/b7d7fd953f> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 203",
        "Polychloorbifenyl 203"@nl-be ;
    schema1:alternateName "2,2',3,4,4',5,5',6-Octachlorobiphenyl",
        "PCB 203",
        "PCB 203"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/cas:52663-76-0>,
        <https://identifiers.org/inchikey:DCPDZFRGNJDWPP-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:40483> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb203" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

