@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/b6e3c15b80> a owl:Class ;
    rdfs:label "Benzo[k]fluoranthene",
        "Benzo[k]fluorantheen"@nl-be ;
    schema1:alternateName "BkFA" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098NDFVH6VFC2XZ0P18FY>,
        pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:34569>,
        <https://identifiers.org/cas:207-08-9>,
        <https://identifiers.org/inchikey:HAXBIWFMXWRORI-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:9158> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "bkfa" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "polycyclic aromatic hydrocarbons" .

