<https://w3id.org/peh/biochementities/c680dbf538> a owl:Class ;
    rdfs:label "Dibenzo[a,e]pyrene",
        "Dibenzo[a,e]pyreen"@nl-be ;
    schema1:alternateName "DBaeP" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098NDFVH6VFC2XZ0P18FY>,
