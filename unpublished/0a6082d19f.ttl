@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/peh/biochementities/0a6082d19f> a owl:Class ;
    rdfs:label "Polychlorinated biphenyl 156",
        "Polychloorbifenyl 156"@nl-be ;
    schema1:alternateName "2,3,3',4,4',5-Hexachlorobiphenyl",
        "PCB 156",
        "PCB 156"@nl-be ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:81522>,
        <https://identifiers.org/cas:38380-08-4>,
        <https://identifiers.org/inchikey:LCXMEXLGMKFLQO-UHFFFAOYSA-N>,
        <https://identifiers.org/pubchem.compound:38019> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "pcb156" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds" ;
    pehterms:isMetaboliteOf <https://w3id.org/peh/biochementities/9c34ebdc76> .

