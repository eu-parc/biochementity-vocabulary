<https://w3id.org/peh/biochementities/a30fa5dd93> a owl:Class ;
    rdfs:label "N-acetyl 4,4'-methylenebis (2-chloroaniline)",
        "N-acetyl 4,4'-methylenebis (2-chloroaniline)"@nl-be ;
    schema1:alternateName "N-(4-((4-Amino-3-chlorophenyl)methyl)-2-chlorophenyl)acetamide",
        "acetyl-MOCA" ;
    schema1:comment """comments: * Parent compound seems to be MOCA
* In PUBCHEM it seems to be this compound: https://pubchem.ncbi.nlm.nih.gov/compound/56272 --> so adding this info. To double check by Anthony
source: https://pubmed.ncbi.nlm.nih.gov/18008389/""" ;
    rdfs:subClassOf <https://w3id.org/peh/biochementities/01KRB098ND3BTCXN6EEBJ8TRXB>,
        pehterms:BioChemEntity ;
    skos:exactMatch "https://identifiers.org/cas:91575-28-9"^^xsd:anyURI,
        "https://identifiers.org/inchikey:JCHPXNSTFVJJLN-UHFFFAOYSA-N"^^xsd:anyURI,
        "https://identifiers.org/pubchem.compound:https://pubchem.ncbi.nlm.nih.gov/compound/56272"^^xsd:anyURI ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "amoca" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] .

