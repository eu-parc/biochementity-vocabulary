<https://w3id.org/peh/biochementities/354482cd50> a owl:Class ;
    rdfs:label "Trans-chlordane",
        "Trans-chloordaan"@nl-be ;
    ns1:RO_0000087 <https://purl.obolibrary.org/obo/CHEBI_25944> ;
    schema1:alternateName "γ-chlordane" ;
    rdfs:subClassOf pehterms:BioChemEntity ;
    skos:exactMatch <https://identifiers.org/CHEBI:39069>,
        <https://identifiers.org/cas:5103-74-2>,
        <https://identifiers.org/inchikey:BIWJNBZANLAXMG-OESJLNMISA-N>,
        <https://identifiers.org/pubchem.compound:12303036> ;
    pehterms:hasContextAlias [ a pehterms:ContextAlias ;
            schema1:alternateName "ychlor" ;
            schema1:identifier "short_name" ;
            pehterms:hasContext <https://ror.org/04gq0w522> ] ;
    pehterms:hasGroupLabel "organochlorine compounds",
        "pesticides" .

